          <label class="flt-item"><span>Session</span><label class="switch"><input type="checkbox" id="flt-session"><span class="slider"></span></label></label>
          <label class="flt-item"><span>Spread</span><label class="switch"><input type="checkbox" id="flt-spread"><span class="slider"></span></label></label>
          <label class="flt-item"><span>Regime</span><label class="switch"><input type="checkbox" id="flt-regime"><span class="slider"></span></label></label>
        </div>
        <div class="controls" style="margin-top:14px">
          <div class="ctrl"><label>Vol floor (atr/px)</label><input id="flt-volmin" type="number" step="0.0001"></div>
          <div class="ctrl"><label>Vol ceiling</label><input id="flt-volmax" type="number" step="0.001"></div>
          <div class="ctrl"><label>Min volume ratio</label><input id="flt-volr" type="number" step="0.1"></div>
          <div class="ctrl"><label>Max spread (bps)</label><input id="flt-maxspread" type="number" step="0.1"></div>
          <div class="ctrl"><label>ADX trend thresh</label><input id="flt-adx" type="number" step="1"></div>
          <button class="btn" id="flt-save">Save Filters</button>
        </div>
        <div class="kv" id="flt-rejects" style="margin-top:10px"></div>
      </div>
