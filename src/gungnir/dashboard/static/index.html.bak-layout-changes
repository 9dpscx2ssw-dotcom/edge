      <div class="card">
        <div class="controls" id="set-learning-form">
          <div class="ctrl">
            <label>Reflection Mode</label>
            <select id="set-reflection-mode">
              <option value="llm">LLM Mode (batch all strategies → 1 call/hour)</option>
              <option value="bayesian">Bayesian Mode (deterministic, 0 LLM calls)</option>
            </select>
          </div>
          <button class="btn" id="set-learning-save">Save</button>
        </div>
      </div>
      <h2 class="sec">Configuration &amp; Runtime</h2>
      <div class="settings-pair">
        <div class="card"><h3>Configuration <span class="win">config.yaml</span></h3><div class="kv" id="set-config">—</div></div>
        <div class="card"><h3>Runtime Settings <span class="win">control.json</span></h3><div class="runtime-summary" id="set-runtime-summary">—</div></div>
      </div>
      <h2 class="sec">Available Strategies</h2>
      <div class="card"><p id="set-strats">—</p></div>
    </div>

  </div>
</div>

<script>
const $ = id => document.getElementById(id);
const charts = {};
const C = { green:'#00d084', red:'#ff3860', mut:'#808892', line:'#3a3f4b', accent:'#ff6b35', amber:'#ffc857', magenta:'#e83e8c' };

async function api(path, opts){
  opts = opts || {};
  // Attach the control-plane token (if the user has set one) on writes.
  const tok = localStorage.getItem('dash_token');
  if(tok){ opts.headers = Object.assign({}, opts.headers, {'X-Dashboard-Token': tok}); }
  let r = await fetch(path, opts);
  if(r.status===401){
    const t = prompt('Dashboard token required for control actions:');
    if(t){ localStorage.setItem('dash_token', t);
      opts.headers = Object.assign({}, opts.headers, {'X-Dashboard-Token': t});
      r = await fetch(path, opts); }
  }
  if(!r.ok){
    let detail='';
    try{ const d=await r.clone().json(); detail=d.error||d.message||''; }catch(e){}
    throw new Error(path+' '+r.status+(detail?': '+detail:''));
  }
  return r.json();
}
function usd(n){ if(n==null||isNaN(n)) return '—'; return '$'+Math.abs(n).toLocaleString(undefined,{maximumFractionDigits:0}); }
function signed(n){ if(n==null||isNaN(n)) return '—'; return (n<0?'-':'+')+usd(n); }
function setPL(el, n){ if(!el) return; el.textContent = signed(n); el.classList.remove('pos','neg'); if(n>0) el.classList.add('pos'); else if(n<0) el.classList.add('neg'); }
function lineChart(id, labels, data, color){
  const el=$(id); if(!el) return;
  if(charts[id]) charts[id].destroy();
  charts[id]=new Chart(el,{type:'line',data:{labels,datasets:[{data,borderColor:color,backgroundColor:color+'22',tension:.15,fill:true,pointRadius:0,borderWidth:2}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
      scales:{y:{ticks:{color:C.mut},grid:{color:C.line}},x:{ticks:{color:C.mut,maxTicksLimit:8},grid:{display:false}}}}});
}
function equityChart(id, realPts, shadowPts, base){
  const el=$(id); if(!el) return;
  if(charts[id]) charts[id].destroy();
  // Prepend the starting balance so both curves begin at the initial account
  // balance rather than 0.
  const real=[base, ...realPts.map(p=>p.equity)];
  const shadow=[base, ...shadowPts.map(p=>p.equity)];
  const labels = Array.from({length: Math.max(real.length, shadow.length)}, (_,i)=>i);
  charts[id]=new Chart(el,{type:'line',data:{labels,datasets:[
      {label:'Real',data:real,borderColor:C.green,backgroundColor:C.green+'22',tension:.15,fill:true,pointRadius:0,borderWidth:2},
      {label:'Shadow',data:shadow,borderColor:C.magenta,backgroundColor:'transparent',borderDash:[4,3],tension:.15,fill:false,pointRadius:0,borderWidth:2},
    ]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},
      tooltip:{callbacks:{label:c=>c.dataset.label+': '+usd(c.parsed.y)}}},
      scales:{y:{ticks:{color:C.mut,callback:v=>usd(v)},grid:{color:C.line}},x:{ticks:{color:C.mut,maxTicksLimit:8},grid:{display:false}}}}});
}
function sparkChart(id, data, color){
  const el=$(id); if(!el) return;
  if(charts[id]) charts[id].destroy();
  charts[id]=new Chart(el,{type:'line',data:{labels:data.map((_,i)=>i+1),datasets:[{data,borderColor:color,backgroundColor:color+'22',tension:.2,fill:true,pointRadius:0,borderWidth:1.5}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{enabled:false}},
      scales:{y:{display:false},x:{display:false}}}});
}
function barChart(id, labels, data){
  const el=$(id); if(!el) return;
  if(charts[id]) charts[id].destroy();
  charts[id]=new Chart(el,{type:'bar',data:{labels,datasets:[{data,backgroundColor:data.map(v=>v>=0?C.green:C.red)}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
      scales:{y:{ticks:{color:C.mut},grid:{color:C.line}},x:{ticks:{color:C.mut},grid:{display:false}}}}});
}

let STATUS = {};
async function loadStatus(){
  try{
    const s = await api('/api/status');
    STATUS = s;
    $('conn').className='conn-dot ok';
    const acc = s.account||{}, pnl = s.pnl||{}, exe = s.execution||{};
    const equity = acc.equity ?? s.equity ?? 0;
    const daily = (s.day_start_equity!=null && s.day_start_equity>0) ? (equity - s.day_start_equity) : null;
    $('m-equity').textContent = usd(equity);
    setPL($('m-closed'), pnl.closed ?? s.closed_pl);
    setPL($('m-open'), pnl.running ?? s.running_pl);
    const shp = s.pnl_shadow||{};
    setPL($('m-sh-closed'), shp.closed);
    setPL($('m-sh-open'), shp.running);
    setPL($('m-daily'), daily);

    // Authoritative control-plane state (not the historical status mode).
    const paper = s.paper_mode ?? ((s.risk_settings||{}).PAPER_TRADE ?? (s.mode!=='live'));
    const mb=$('mode-btn'); mb.textContent = paper?'PAPER':'LIVE';
    mb.classList.toggle('active', true); mb.classList.toggle('danger', !paper);
    mb.title = paper ? (s.live_block_reason || 'Paper execution is active') : 'Live execution is active';
    const on = s.agent_enabled ?? !s.paused;
    const ab=$('agent-btn'); ab.textContent = on?'AGENT ON':'AGENT OFF';
    ab.classList.toggle('active', on); ab.classList.toggle('danger', !on);
    // Offline-RL veto toggle (only meaningful when a policy is loaded).
    const kb=$('kill-btn'); const killed=!!(s.kill_switch ?? s.killed);
    kb.textContent = killed?'KILLED':'KILL';
    kb.classList.toggle('active', killed); kb.classList.toggle('danger', killed);
    $('kill-banner').classList.toggle('on', killed);
    const og=$('offgate-btn'); const gate=!!s.offline_gate;
    og.textContent = gate?'RL VETO ON':'RL VETO';
    og.classList.toggle('active', gate);
    og.style.opacity = s.offline_policy_loaded? '1':'0.45';
    og.title = s.offline_policy_loaded
      ? 'Offline RL veto — blocks signals the offline policy disagrees with (veto-only)'
      : 'No offline policy loaded — train one and set rl.offline_advisory';

    // overview account card
    $('ov-equity').textContent = usd(equity);
    $('ov-balance').textContent = usd(acc.balance ?? s.balance);
    setPL($('ov-running'), pnl.running ?? s.running_pl);
    setPL($('ov-closed'), pnl.closed ?? s.closed_pl);
    $('ov-real-open').textContent = exe.open_trades ?? 0;
    $('ov-real-total').textContent = exe.paper_trade_count ?? (s.trade_counts||{}).real ?? 0;
    $('ov-shadow-open').textContent = exe.shadow_open_trades ?? 0;
    $('ov-shadow-total').textContent = exe.shadow_trade_count ?? (s.trade_counts||{}).shadow ?? 0;
    const rl = s.rl||{};
    $('ov-rl').textContent = (rl.updates ?? rl.n_updates ?? 0)+' updates'+(rl.reward!=null?(' · reward '+(+rl.reward).toFixed(3)):'');

    // latest signal
    const bt = (s.signal||{}).best_trade||{};
    const conf = Math.round(bt.confidence ?? 0);   // server sends percent already
    $('sig-conf').innerHTML = conf+'%<br><span>CONF</span>';
    const dir = bt.direction||'HOLD';
    const badge=$('sig-badge'); badge.textContent=dir; badge.className='signal-badge'+(dir==='BUY'?' buy':dir==='SELL'?' sell':'');
    if(bt.symbol){
      $('sig-status').textContent = dir+' '+bt.symbol+(bt.strategy_name?(' · '+bt.strategy_name):'');
      $('sig-detail').textContent=(s.signal||{}).analysis||'—';
      // Show sentiment, prediction, RL
      const views = s.views || {};
      const view = views[bt.symbol] || {};
      // Live tick price (updates every loop) with the closed-bar price as fallback.
      const px = view.live_price ?? view.price;
      if(px != null) $('sig-status').textContent += ' @ ' + px;
      const sentiment = view.sentiment_score;
      const prediction = view.prediction_conf;
      const rlScore = bt.rl_confidence;
      if(sentiment != null || prediction != null || rlScore != null){
        $('sig-soft').style.display='block';
        $('sig-sentiment').textContent = sentiment != null ? (sentiment>0?'+':'')+sentiment.toFixed(2) : '—';
        $('sig-prediction').textContent = prediction != null ? (prediction*100).toFixed(0)+'%' : '—';
        $('sig-rl').textContent = rlScore != null ? (rlScore*100|0)+'%' : '—';
      } else { $('sig-soft').style.display='none'; }
    }
    else {
      $('sig-status').textContent='No active signal';
      $('sig-detail').textContent='Waiting for the agent…';
      $('sig-soft').style.display='none';
    }
    renderConsensus(s.views||{});
  }catch(e){ $('conn').className='conn-dot bad'; }
}

// Consensus strip — one chip per symbol the aggregator is voting on. Hidden
// entirely when aggregation is off (no view carries a `consensus` block).
function renderConsensus(views){
  const sec=document.getElementById('ov-consensus-sec');
  const host=document.getElementById('ov-consensus');
  if(!sec||!host) return;
  const rows=Object.entries(views).filter(([,v])=>v&&v.consensus)
    .map(([sym,v])=>({sym,...v.consensus}));
  if(!rows.length){ sec.style.display='none'; return; }
  sec.style.display='block';
  rows.sort((a,b)=>Math.abs(b.score||0)-Math.abs(a.score||0));
  host.innerHTML=rows.map(r=>{
    const sc=+r.score||0, dir=sc>=0?'pos':'neg', w=Math.min(50,Math.abs(sc)*50);
    const fill=sc>=0?`left:50%;width:${w}%;background:var(--green)`
                    :`right:50%;width:${w}%;background:var(--red)`;
    const opp=Math.round((r.opposing||0)*100);
    const act=(r.action||'none').toLowerCase();
    const dg=r.diagnostics||{};
    const raw=Number.isFinite(+dg.raw_score)?(+dg.raw_score).toFixed(2):'—';
    const hz=Object.entries(dg.horizons||{}).map(([k,v])=>`${k} ${(+v).toFixed(2)}`).join(' · ');
    return `<div class="cons-chip">
      <div class="top"><span class="sym">${r.sym}</span><span class="cons-act ${act}">${act}</span></div>
      <div class="cons-meter"><div class="z"></div><div class="fill" style="${fill}"></div></div>
      <div class="row">
        <span>score <b class="cons-score ${dir}">${sc>=0?'+':''}${sc.toFixed(2)}</b></span>
        <span>raw <b>${raw}</b></span>
        <span>opp <b${opp>=35?' style="color:var(--red)"':''}>${opp}%</b></span>
        <span><b>${r.stances||0}</b> <span style="opacity:.6">votes</span></span>
      </div>${hz?`<div style="font-size:10px;opacity:.65;margin-top:4px">horizons: ${hz}</div>`:''}</div>`;
  }).join('');
}

async function loadOverviewExtras(){
  try{
    const eq = await api('/api/equity');
    const real = eq.real||[], shadow = eq.shadow||[], base = eq.base||0;
    // Shadow P/L is realized paper-trade pnl — kept separate from real equity.
    setPL($('ov-shadow-pl'), shadow.length ? shadow[shadow.length-1].cum_pnl : null);
    if(real.length || shadow.length){ $('ov-eq-empty').style.display='none'; $('ov-eq-chart').style.display='block';
      equityChart('ov-eq-chart', real, shadow, base);
    } else { $('ov-eq-empty').style.display='flex'; $('ov-eq-chart').style.display='none'; }
  }catch(e){}
  try{
    const d = await api('/api/strategies');
    const rows = (d.strategies||[]).filter(s=>s.performance && s.performance.count>0);
    if(rows.length) barChart('ov-strat-chart', rows.map(s=>'S'+s.strategy), rows.map(s=>s.performance.pnl));
    else barChart('ov-strat-chart', (d.strategies||[]).slice(0,12).map(s=>'S'+s.strategy), (d.strategies||[]).slice(0,12).map(s=>s.performance?.pnl||0));
  }catch(e){}
}

async function loadMarkets(){
  const g=$('mkt-grid');
  try{
    const d = await api('/api/markets');
    if(!d.markets || !d.markets.length){ g.innerHTML='<div class="empty-state">No market data yet.</div>'; return; }
    g.innerHTML = d.markets.map(m=>{
      const dir=m.rl_direction||'HOLD'; const dc=dir==='BUY'?'b-buy':dir==='SELL'?'b-sell':'b-hold';
      return `<div class="market-card ${m.enabled?'':'disabled'}">
        <div class="mc-head"><div><div class="mc-sym">${m.symbol}</div><div class="mc-cat">${m.category||''}</div></div>
          <label class="switch"><input type="checkbox" ${m.enabled?'checked':''} onchange="toggleMarket('${m.symbol}',this.checked)"><span class="slider"></span></label></div>
        <div class="mc-price">${m.price!=null?(+m.price).toLocaleString(undefined,{maximumFractionDigits:4}):'—'}</div>
        <div class="mc-row"><span>RL</span><span><span class="badge ${dc}">${dir}</span></span></div>
        <div class="mc-row"><span>Trades</span><span>${m.trades||0}</span></div>
        <div class="mc-row"><span>Win rate</span><span>${m.win_rate!=null?m.win_rate+'%':'—'}</span></div>
        <div class="mc-row"><span>P&amp;L</span><span style="color:${(m.pnl||0)>=0?C.green:C.red}">${signed(m.pnl||0)}</span></div>
        ${mpsBlock(m.mps)}
        ${consensusBlock(m.consensus)}
        ${m.offline_action?`<div class="mc-row"><span>Offline RL</span><span class="badge ${m.offline_action==='LONG'?'b-buy':m.offline_action==='SHORT'?'b-sell':'b-hold'}">${m.offline_action} · advisory</span></span></div>`:''}
      </div>`;
    }).join('');
  }catch(e){ g.innerHTML='<div class="empty-state">Failed to load markets.</div>'; }
}
function consensusBlock(c){
  if(!c) return '';
  const score=+(c.score||0), action=(c.action||'none').toLowerCase();
  const stances=+(c.stances||0), opposing=Math.round((c.opposing||0)*100);
  const dg=c.diagnostics||{}, raw=Number.isFinite(+dg.raw_score)?(+dg.raw_score).toFixed(2):'—';
  const hz=Object.entries(dg.horizons||{}).map(([k,v])=>`${k} ${(+v).toFixed(2)}`).join(' · ');
  const state=action==='none' && !stances ? 'NO VOTES' : action.toUpperCase();
  const color=action==='buy'?'var(--green)':action==='sell'?'var(--red)':action==='veto'?'var(--amber)':'var(--mut)';
  return `<div class="mc-cons"><div class="cons-head"><span class="cons-label">Consensus</span><span class="cons-state" style="color:${color}">${state}</span></div>
    <div class="cons-grid"><div class="cons-cell"><div class="k">Score</div><div class="v" style="color:${score>=0?C.green:C.red}">${score>=0?'+':''}${score.toFixed(2)}</div></div>
    <div class="cons-cell"><div class="k">Raw</div><div class="v">${raw}</div></div><div class="cons-cell"><div class="k">Votes</div><div class="v">${stances}</div></div><div class="cons-cell"><div class="k">Opposition</div><div class="v">${opposing}%</div></div></div>
    <div class="cons-note">${hz?`Horizon weights: ${hz}`:''} ${c.reason||'Weighted strategy consensus'}</div></div>`;
}
function mpsBlock(mps){
  if(!mps) return '';
  const name = mps.strategy_name || (mps.strategy!=null?('S'+mps.strategy):'—');
  const pnl = mps.pnl||0;
  // Profit factor: null = no losing trades → ∞ when in profit, else —.
  const pf = mps.profit_factor!=null ? mps.profit_factor.toFixed(2) : (pnl>0?'∞':'—');
  const wr = mps.win_rate!=null ? mps.win_rate+'%' : '—';
  return `<div class="mc-mps">
    <div class="mps-head"><span class="mps-label">Most profitable strategy</span><span class="mps-name" title="${name}">${mps.strategy!=null?'S'+mps.strategy+' · ':''}${name}</span></div>
    <div class="mps-grid">
      <div class="mps-cell"><div class="k">Win rate</div><div class="v">${wr}</div></div>
      <div class="mps-cell"><div class="k">P&amp;L</div><div class="v" style="color:${pnl>=0?C.green:C.red}">${signed(pnl)}</div></div>
      <div class="mps-cell"><div class="k">Profit factor</div><div class="v">${pf}</div></div>
    </div></div>`;
}
async function toggleMarket(sym, enabled){
  try{ await api('/api/instruments/toggle',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({symbol:sym,enabled})}); loadMarkets(); }catch(e){}
}

async function loadStrategies(){
  try{
    const d = await api('/api/strategies');
    const ss = d.strategies||[];
    const traded = ss.filter(s=>s.performance && s.performance.count>0);
    const base = (traded.length?traded:ss.slice(0,12));
    barChart('str-chart', base.map(s=>'S'+s.strategy), base.map(s=>s.performance?.pnl||0));
    $('str-list').className='strat-grid';
    $('str-list').innerHTML = ss.map(s=>{
      const p=s.performance||{};
      const pnl=p.pnl||0; const pClr=pnl>=0?C.green:C.red;
      const md = s.mode||'off';
      return `<div class="strat-card ${s.enabled?'':'off'}">
        <div class="sc-head">
          <span class="sc-num">S${s.strategy}</span>
          <span class="sc-name">${s.name}</span>
          <div class="mode-seg" title="off = disabled · shadow = paper-trade only · live = real orders on the connected account">
            <button class="ms-btn ${md==='off'?'on-off':''}" onclick="setStratMode('${s.name}','off')">OFF</button>
            <button class="ms-btn ${md==='shadow'?'on-shadow':''}" onclick="setStratMode('${s.name}','shadow')">SHDW</button>
            <button class="ms-btn ${md==='live'?'on-live':''}" onclick="setStratMode('${s.name}','live')">LIVE</button>
          </div>
        </div>
        <div class="sc-desc">${s.indicators||''}${(s.excluded_symbols&&s.excluded_symbols.length)?`<br><span style="color:var(--amber);font-size:11px" title="${s.excluded_symbols.join(', ')}">⛔ ${s.excluded_symbols.length} symbol${s.excluded_symbols.length>1?'s':''} pruned (learned)</span>`:''}</div>
        <div class="sc-spark"><canvas id="sc-spark-${s.strategy}"></canvas></div>
        <div class="sc-stats">
          <div class="sc-stat"><div class="lbl">P&amp;L</div><div class="val" style="color:${pClr}">${signed(pnl)}</div></div>
          <div class="sc-stat"><div class="lbl">Win rate</div><div class="val">${p.win_rate||0}%</div></div>
          <div class="sc-stat"><div class="lbl">W / L</div><div class="val wl"><span class="w">${p.wins||0}</span>/<span class="l">${p.losses||0}</span></div></div>
        </div>
        <div class="sc-stats">
          <div class="sc-stat"><div class="lbl">Trades</div><div class="val">${p.count||0}</div></div>
          <div class="sc-stat"><div class="lbl">Profit factor</div><div class="val">${p.profit_factor==null?'∞':(p.profit_factor||0)}</div></div>
          <div class="sc-stat"><div class="lbl">Avg conf</div><div class="val">${p.avg_confidence!=null?p.avg_confidence+'%':'—'}</div></div>
        </div>
        ${topSymBlock(s.top_symbols)}
      </div>`;
    }).join('');
    renderInstrumentStrategy(d.instrument_strategy||{});
    // Draw the P/L sparkline for each strategy card.
    ss.forEach(s=>{ const c=s.performance&&s.performance.curve; if(c&&c.length) sparkChart('sc-spark-'+s.strategy, c, (c[c.length-1]>=0?C.green:C.red)); });
  }catch(e){ $('str-list').innerHTML='<div class="empty-state">Failed to load strategies.</div>'; }
}
function renderInstrumentStrategy(m){
  const host=$('str-matrix'); if(!host) return;
  const inst=m.instruments||[], strats=m.strategies||[], cells=m.cells||[];
  if(!inst.length||!strats.length){ host.innerHTML='<div class="empty-state">No instrument × strategy performance data yet.</div>'; return; }
  const byKey={}; cells.forEach(c=>{ byKey[c.symbol+'|'+c.strategy]=c; });
  const pnls=cells.map(c=>Number(c.pnl)||0).filter(v=>v!==0);
  const maxPnl=Math.max(1,...pnls.map(v=>Math.abs(v)));
  const money=v=>{const n=Number(v)||0;return (n>=0?'+$':'-$')+Math.abs(n).toFixed(2)};
  const cell=(sym,st)=>{
    const c=byKey[sym+'|'+st.strategy]; if(!c) return '<td><span class="is-cell is-flat">—</span></td>';
    const pnl=Number(c.pnl)||0, wr=c.win_rate==null?'—':`${c.win_rate}%`, heat=(0.12+0.38*Math.min(1,Math.abs(pnl)/maxPnl)).toFixed(2);
    const cls=pnl>0?'is-pos':pnl<0?'is-neg':'is-flat';
    const title=`${sym} × ${c.strategy_name||'S'+st.strategy}: win rate ${wr}, P/L ${money(pnl)}, ${c.trades||0} closed trades`;
