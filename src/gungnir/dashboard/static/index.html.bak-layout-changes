// ── Tab switching + lazy load ─────────────────────────────────────────────
const LOADERS = {
  overview: loadOverviewExtras, discover: loadDiscover, markets: loadMarkets,
  strategies: loadStrategies, intelligence: loadIntelligence, learning: loadLearning,
  signals: loadSignals, trades: loadTrades, reports: loadReports, settings: loadSettings,
};
const TITLES = {overview:'Overview',discover:'Discover',markets:'Markets',strategies:'Strategies',intelligence:'Intelligence',learning:'Learning / RL',signals:'Signals',trades:'Trades',reports:'Reports',backtest:'Backtest',settings:'Settings'};
// Tabs that hold editable forms — don't auto-refresh them out from under the
// user mid-edit. They load once on tab switch and on demand only. Reports is
// a heavier aggregation and stable within a window — load on switch, not every
// 5s poll (the segmented control re-renders instantly from cached data).
const NO_POLL = new Set(['settings','backtest','reports']);
let activeTab='overview';
function switchTab(tab){
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.toggle('active', b.dataset.tab===tab));
  document.querySelectorAll('.tab').forEach(t=>t.classList.toggle('active', t.id===tab));
  $('page-title').textContent = TITLES[tab]||'Overview';
  activeTab=tab;
  if(LOADERS[tab]) LOADERS[tab]();
}
document.querySelectorAll('.nav-btn').forEach(b=>b.addEventListener('click', ()=>switchTab(b.dataset.tab)));

// ── Data freshness indicator ──────────────────────────────────────────────
// Reads the agent's published `ts` and shows how stale it is. Runs off the
// global STATUS so it keeps counting up (and goes red) even when a fetch fails
// or the agent's loop stalls — which is exactly when you need to see it.
function updateFreshness(){
  const el = $('data-fresh'); if(!el) return;
  const ts = (STATUS||{}).ts;
  if(!ts){ el.textContent='no data'; el.style.color='var(--red)'; return; }
  const age = Math.max(0, (Date.now() - new Date(ts).getTime())/1000);
  el.textContent = age<2 ? '● live'
    : '● updated '+(age<60 ? Math.round(age)+'s' : Math.round(age/60)+'m')+' ago';
  el.style.color = age<20 ? 'var(--green)'
    : age<90 ? 'var(--amber)' : 'var(--red)';
}

// ── Boot + polling ────────────────────────────────────────────────────────
async function tick(){ await loadStatus(); updateFreshness(); if(LOADERS[activeTab] && !NO_POLL.has(activeTab)) LOADERS[activeTab](); }
loadStatus().then(loadOverviewExtras);
setInterval(tick, 5000);
// Tick the freshness clock every second so a stalling backend is visible fast.
setInterval(updateFreshness, 1000);
</script>
