<!DOCTYPE html>
<html lang="en"><head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Odin — AI Trading Console</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
  :root{
    --bg:#0a0a0f; --panel:#1a1a24; --panel2:#242a35; --line:#3a3f4b; --line2:#4a5060;
    --txt:#f5f5f5; --mut:#808892; --accent:#ff6b35; --green:#00d084;
    --red:#ff3860; --amber:#ffc857; --purple:#9b59b6; --blue:#3498db;
    --magenta:#e83e8c;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{background:var(--bg);color:var(--txt);font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;font-size:14px}

  /* ── Layout ────────────────────────────────────────────────────────────── */
  .container{display:grid;grid-template-columns:80px 1fr;grid-template-rows:80px 1fr;min-height:100vh;gap:0}

  /* ── Sidebar ───────────────────────────────────────────────────────────── */
  .sidebar{grid-column:1;grid-row:1/3;background:var(--panel);border-right:1px solid var(--line);display:flex;flex-direction:column;align-items:center;padding:16px 0;gap:16px;overflow:hidden}
  .sidebar .logo-area{width:50px;height:50px;border-radius:8px;background:var(--accent);color:#fff;font-weight:800;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0}
  .sidebar nav{flex:1;display:flex;flex-direction:column;gap:12px;align-items:center;width:100%}
  .sidebar nav button{background:none;border:none;color:var(--mut);padding:4px;font-size:18px;cursor:pointer;border-radius:6px;transition:all .2s;width:50px;height:50px;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;gap:2px;overflow:hidden}
  .sidebar nav button svg{stroke:currentColor;fill:none;flex-shrink:0}
  .sidebar nav button span{font-size:8px;font-weight:700;letter-spacing:.3px;line-height:1;text-transform:uppercase}
  .sidebar nav button:hover{color:var(--txt);background:rgba(255,255,255,.05)}
  .sidebar nav button.active{color:var(--accent);background:rgba(255,107,53,.1)}
  .sidebar nav button.active::before{content:'';position:absolute;left:0;top:50%;transform:translateY(-50%);width:3px;height:30px;background:var(--accent);border-radius:0 3px 3px 0}

  /* ── Top Bar ───────────────────────────────────────────────────────────── */
  .topbar{grid-column:2;grid-row:1;background:var(--panel);border-bottom:1px solid var(--line);display:flex;align-items:center;justify-content:space-between;padding:0 28px;gap:20px}
  .topbar .title{font-size:20px;font-weight:700;letter-spacing:.3px}
  .topbar .right-section{display:flex;align-items:center;gap:20px}
  .topbar .metrics{display:flex;align-items:center;gap:24px}
  .topbar .metric-item{display:flex;flex-direction:column;align-items:flex-end}
  .topbar .metric-label{font-size:10px;color:var(--mut);text-transform:uppercase;letter-spacing:.4px}
  .topbar .metric-value{font-size:16px;font-weight:400;margin-top:2px;color:var(--txt)}
  .topbar .metric-value.bold{font-weight:800}
  .topbar .metric-value.pos{color:var(--green)}
  .topbar .metric-value.neg{color:var(--red)}
  .topbar .divider{width:1px;height:40px;background:var(--line)}
  .topbar .metric-group{display:flex;flex-direction:column;align-items:flex-end;gap:3px}
  .topbar .metric-label.shadow{color:var(--magenta)}
  .topbar .mg-rows{display:flex;flex-direction:column;gap:1px}
  .topbar .mg-row{display:flex;align-items:baseline;justify-content:flex-end;gap:8px;line-height:1.25}
  .topbar .mg-row .mg-k{font-size:9px;text-transform:uppercase;letter-spacing:.3px;color:var(--mut)}
  .topbar .mg-row .mg-v{font-size:13px;font-weight:600;min-width:48px;text-align:right;color:var(--txt)}
  .topbar .mg-v.pos{color:var(--green)} .topbar .mg-v.neg{color:var(--red)}
  .conn-dot{width:8px;height:8px;border-radius:50%;background:var(--mut);flex-shrink:0}
  .conn-dot.ok{background:var(--green)}
  .conn-dot.bad{background:var(--red)}

  /* ── Toggle Buttons ────────────────────────────────────────────────────── */
  .toggle-group{display:flex;gap:8px}
  .toggle-btn{padding:6px 12px;border-radius:6px;font-size:10px;font-weight:700;border:1.5px solid var(--line);background:transparent;color:var(--mut);cursor:pointer;transition:all .2s;text-transform:uppercase;letter-spacing:.4px}
  .toggle-btn:hover{border-color:var(--txt);color:var(--txt)}
  .toggle-btn.active{border-color:var(--green);color:var(--green)}
  .toggle-btn.active.danger{border-color:var(--red);color:var(--red)}

  /* ── Main Content ──────────────────────────────────────────────────────── */
  .main{grid-column:2;grid-row:2;padding:28px;overflow-y:auto}
  .tab{display:none}
  .tab.active{display:block}
  h2.sec{font-size:11px;text-transform:uppercase;letter-spacing:1.2px;color:var(--mut);margin:24px 0 16px;font-weight:600;display:flex;align-items:center;justify-content:space-between}
  h2.sec:first-child{margin-top:0}

  .settings-pair{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px;margin-top:0}.settings-pair>.card{min-width:0}.runtime-summary{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}.runtime-summary .kv{min-width:0}.runtime-summary .k{display:block}.runtime-summary .v{display:block;overflow-wrap:anywhere}@media(max-width:800px){.settings-pair{grid-template-columns:1fr}.runtime-summary{grid-template-columns:1fr 1fr}}.card{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:20px;margin-bottom:16px;transition:all .2s}
  .card h3{font-size:14px;font-weight:700;margin-bottom:12px;color:var(--txt)}
  .card p{font-size:13px;line-height:1.6;color:var(--mut)}

  .grid{display:grid;gap:16px}
  .grid.cols-3{grid-template-columns:repeat(auto-fit,minmax(280px,1fr))}

  .badge{display:inline-block;padding:2px 7px;border-radius:4px;font-size:10px;font-weight:700}
  .b-buy{background:rgba(0,208,132,.15);color:var(--green)}
  .b-sell{background:rgba(255,56,96,.15);color:var(--red)}
  .b-hold{background:rgba(128,136,146,.15);color:var(--mut)}

  /* ── Account Grid ──────────────────────────────────────────────────────── */
  .account-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  .metric-block{margin-bottom:16px}
  .metric-label{font-size:11px;text-transform:uppercase;letter-spacing:.4px;color:var(--mut);margin-bottom:8px;font-weight:600;display:block}
  .balance-display{display:flex;flex-direction:column;gap:6px}
  .balance-value{font-size:24px;font-weight:800;color:var(--txt)}
  .balance-bar{height:2px;background:var(--line);border-radius:1px}
  .balance-text{font-size:11px;color:var(--mut)}
  .pnl-display{font-size:13px;color:var(--txt)}
  .pnl-line{display:flex;justify-content:space-between}
  .pnl-value{font-weight:600}
  .section-divider{height:1px;background:var(--line);margin:12px 0}
  .execution-block{margin-bottom:12px}
  .section-title{font-size:10px;text-transform:uppercase;letter-spacing:.4px;color:var(--mut);font-weight:600;margin-bottom:6px}
  .exec-items{display:flex;flex-direction:column;gap:4px;font-size:12px;color:var(--txt)}
  .exec-item strong{color:var(--green)}
  .rl-reward-block{margin-top:12px}
  .reward-value{font-size:12px;color:var(--mut)}
  .empty-state{color:var(--mut);font-size:13px;text-align:center;padding:40px 20px;display:flex;align-items:center;justify-content:center;min-height:200px}
  .chart-card{position:relative;min-height:240px}
  .chart-card canvas{max-height:260px}

  /* ── Signal Card ───────────────────────────────────────────────────────── */
  .signal-card{display:flex;align-items:center;gap:20px}
  .signal-content{display:flex;align-items:center;gap:20px;width:100%}
  .confidence-circle{width:100px;height:100px;border-radius:50%;background:var(--panel2);border:2px solid var(--line);display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .confidence-text{text-align:center;font-size:28px;font-weight:800;line-height:1.2;color:var(--amber)}
  .confidence-text span{display:block;font-size:10px;text-transform:uppercase;letter-spacing:.3px;color:var(--mut);margin-top:2px;font-weight:600}
  .signal-info{flex:1}
  .signal-badge{display:inline-block;padding:4px 8px;background:var(--amber);color:#000;font-size:10px;font-weight:700;border-radius:4px;margin-bottom:6px}
  .signal-badge.buy{background:var(--green);color:#000}
  .signal-badge.sell{background:var(--red);color:#fff}
  .signal-status{font-size:14px;font-weight:600;color:var(--txt);margin-bottom:4px}
  .signal-waiting{font-size:12px;color:var(--mut)}

  /* ── Tables ────────────────────────────────────────────────────────────── */
  .data-table{width:100%;font-size:12px;border-collapse:collapse}
  .data-table th{background:var(--panel2);padding:8px 10px;text-align:left;font-weight:600;border-bottom:1px solid var(--line);color:var(--mut);text-transform:uppercase;font-size:10px;letter-spacing:.4px}
  .data-table td{padding:8px 10px;border-bottom:1px solid var(--line)}
  .data-table tr:hover td{background:var(--panel2)}
  .data-table .pos{color:var(--green)}
  .data-table .neg{color:var(--red)}

  /* ── Kill banner ───────────────────────────────────────────────────────── */
  #kill-banner{display:none;background:var(--red);color:#fff;text-align:center;
    padding:9px 14px;font-size:13px;font-weight:800;letter-spacing:.8px}
  #kill-banner.on{display:block}
  @keyframes killpulse{0%,100%{opacity:1}50%{opacity:.75}}
  #kill-banner.on{animation:killpulse 1.6s ease-in-out infinite}

  /* ── Toggle switch ─────────────────────────────────────────────────────── */
  .switch{position:relative;display:inline-block;width:38px;height:20px;flex-shrink:0}
  .switch input{opacity:0;width:0;height:0}
  .switch .slider{position:absolute;cursor:pointer;inset:0;background:var(--line);border-radius:20px;transition:.2s}
  .switch .slider:before{position:absolute;content:"";height:14px;width:14px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.2s}
  .switch input:checked + .slider{background:var(--green)}
  .switch input:checked + .slider:before{transform:translateX(18px)}

  /* ── Strategy mode selector (off / shadow / live) ──────────────────────── */
  .mode-seg{display:inline-flex;border:1px solid var(--line);border-radius:6px;overflow:hidden;flex-shrink:0}
  .mode-seg .ms-btn{background:transparent;border:none;color:var(--mut);font-size:10px;font-weight:600;
    padding:4px 8px;cursor:pointer;letter-spacing:.5px;transition:.15s}
  .mode-seg .ms-btn:not(:last-child){border-right:1px solid var(--line)}
  .mode-seg .ms-btn.on-off{background:var(--line);color:var(--txt)}
  .mode-seg .ms-btn.on-shadow{background:rgba(236,72,153,.18);color:var(--magenta,#ec4899)}
  .mode-seg .ms-btn.on-live{background:rgba(16,185,129,.18);color:var(--green)}

  /* ── Market cards ──────────────────────────────────────────────────────── */
  .market-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px}
  .market-card{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:14px;transition:all .2s}
  .market-card:hover{border-color:var(--line2)}
  .market-card.disabled{opacity:.5}
  .market-card .mc-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
  .market-card .mc-sym{font-size:15px;font-weight:700}
  .market-card .mc-cat{font-size:9px;text-transform:uppercase;letter-spacing:.4px;color:var(--mut)}
  .market-card .mc-price{font-size:18px;font-weight:700;margin-bottom:8px}
  .market-card .mc-row{display:flex;justify-content:space-between;font-size:11px;color:var(--mut);margin-top:4px}
  .market-card .mc-row span:last-child{color:var(--txt);font-weight:600}
  .market-card .mc-mps{margin-top:10px;padding:8px 9px;border:1px solid var(--line);border-radius:8px;background:rgba(124,92,255,.06)}
  .market-card .mc-mps .mps-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
  .market-card .mc-mps .mps-label{font-size:8px;text-transform:uppercase;letter-spacing:.5px;color:var(--accent);font-weight:800}
  .market-card .mc-mps .mps-name{font-size:11px;font-weight:700;color:var(--txt);text-align:right;max-width:62%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .market-card .mc-mps .mps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px}
  .market-card .mc-mps .mps-cell{text-align:center}
  .market-card .mc-mps .mps-cell .k{font-size:8px;text-transform:uppercase;letter-spacing:.3px;color:var(--mut)}
  .market-card .mc-mps .mps-cell .v{font-size:12px;font-weight:700;color:var(--txt)}
  .market-card .mc-cons{margin-top:10px;padding:8px 9px;border:1px solid var(--line);border-radius:8px;background:rgba(16,185,129,.05)}
  .market-card .mc-cons .cons-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
  .market-card .mc-cons .cons-label{font-size:8px;text-transform:uppercase;letter-spacing:.5px;color:var(--accent);font-weight:800}
  .market-card .mc-cons .cons-state{font-size:10px;font-weight:800;text-transform:uppercase}
  .market-card .mc-cons .cons-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;text-align:center}
  .market-card .mc-cons .cons-cell .k{font-size:8px;text-transform:uppercase;letter-spacing:.3px;color:var(--mut)}
  .market-card .mc-cons .cons-cell .v{font-size:12px;font-weight:700;color:var(--txt)}
  .market-card .mc-cons .cons-note{font-size:9px;color:var(--mut);margin-top:6px;line-height:1.3}
  .is-card{margin-top:14px;width:100%;min-width:0}
  .is-legend{display:flex;align-items:center;gap:10px;color:var(--mut);font-size:10px;margin:0 0 9px}
  .is-legend .swatch{width:12px;height:12px;border-radius:3px;display:inline-block}
  .is-legend .pos{background:rgba(16,185,129,.55)}
  .is-legend .neg{background:rgba(239,68,68,.55)}
  .is-legend .flat{background:rgba(128,136,146,.20)}
  .is-table-wrap{width:100%;overflow:hidden}
  .is-table{width:100%;table-layout:fixed;border-collapse:collapse;font-size:9px}
  .is-table th,.is-table td{padding:4px 2px;border-bottom:1px solid var(--line);text-align:center;white-space:nowrap;overflow:hidden}
  .is-table th:first-child,.is-table td:first-child{width:72px;text-align:left}
  .is-table th{font-size:8px;text-transform:uppercase;letter-spacing:.2px;color:var(--mut);font-weight:700}
  .is-cell{font-weight:800;border-radius:4px;padding:3px 1px;display:block;line-height:1.05;min-height:25px}
  .is-cell small{font-size:8px;font-weight:600;opacity:.9}
  .is-pos{color:var(--green);background:rgba(16,185,129,var(--heat,.16))}
  .is-neg{color:var(--red);background:rgba(239,68,68,var(--heat,.16))}
  .is-flat{color:var(--mut);background:rgba(128,136,146,.10)}
  @media(max-width:800px){.is-table{font-size:8px}.is-table th:first-child,.is-table td:first-child{width:58px}.is-cell{font-size:8px}.is-cell small{font-size:7px}}

  /* Best-symbols block on strategy cards (mirror of the instrument cards'
     "most profitable strategy" panel) */
  .sc-tops{margin-top:2px;padding:8px 9px;border:1px solid var(--line);border-radius:8px;background:rgba(124,92,255,.06)}
  .sc-tops .st-label{font-size:8px;text-transform:uppercase;letter-spacing:.5px;color:var(--accent);font-weight:800;margin-bottom:5px}
  .sc-tops .st-row{display:grid;grid-template-columns:1fr 54px 46px 66px;gap:4px;font-size:11px;padding:1px 0;color:var(--txt);font-variant-numeric:tabular-nums}
  .sc-tops .st-row span{text-align:right}
  .sc-tops .st-row .st-sym{text-align:left;font-weight:700}
  .sc-tops .st-row.st-head{color:var(--mut);font-size:8px;text-transform:uppercase;letter-spacing:.3px;font-weight:600}

  /* ── Strategy rows ─────────────────────────────────────────────────────── */
  .strat-row{display:flex;align-items:center;gap:12px;padding:10px 14px;border:1px solid var(--line);border-radius:8px;margin-bottom:8px;background:var(--panel)}
  .strat-row .s-num{font-size:11px;font-weight:800;color:var(--accent);width:34px}
  .strat-row .s-name{flex:1;font-size:13px;font-weight:600}
  .strat-row .s-desc{font-size:11px;color:var(--mut);font-weight:400}
  .strat-row .s-stat{font-size:11px;color:var(--mut);min-width:70px;text-align:right}

  /* ── Forms / controls ──────────────────────────────────────────────────── */
  .controls{display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;margin-bottom:16px}
  .ctrl{display:flex;flex-direction:column;gap:4px}
  .ctrl label{font-size:10px;text-transform:uppercase;letter-spacing:.4px;color:var(--mut);font-weight:600}
  .ctrl input,.ctrl select{background:var(--panel2);border:1px solid var(--line);color:var(--txt);border-radius:6px;padding:7px 10px;font-size:13px;min-width:120px}
  .btn{background:var(--accent);color:#fff;border:none;border-radius:6px;padding:8px 16px;font-size:12px;font-weight:700;cursor:pointer;text-transform:uppercase;letter-spacing:.4px}
  .btn:hover{filter:brightness(1.1)}
  .btn.ghost{background:transparent;border:1.5px solid var(--line);color:var(--mut)}
  .btn.ghost:hover{border-color:var(--txt);color:var(--txt)}
  .settings-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px}
  .kv{font-size:12px;line-height:1.8}
  .kv .k{color:var(--mut)}
  .kv .v{color:var(--txt);font-weight:600}

  /* ── Overview account header (big equity + inline P&L) ─────────────────── */
  .acct-head{display:flex;justify-content:space-between;align-items:flex-start;gap:24px;flex-wrap:wrap}
  .acct-equity{display:flex;flex-direction:column;gap:6px;flex:1;min-width:200px}
  .equity-big{font-size:56px;font-weight:800;line-height:1;color:var(--txt);letter-spacing:-1px}
  .acct-pnl{display:flex;flex-direction:column;gap:8px;min-width:180px}
  .acct-pnl .pnl-row{display:flex;justify-content:space-between;gap:18px;font-size:13px}
  .acct-pnl .pnl-row .k{color:var(--mut)}
  .acct-pnl .pnl-row .v{font-weight:700}
  .legend{display:flex;gap:16px;align-items:center;font-size:11px;color:var(--mut)}
  .legend .lg{display:flex;align-items:center;gap:6px}
  .legend .swatch{width:16px;height:3px;border-radius:2px;display:inline-block}
  .legend .swatch.dash{background:repeating-linear-gradient(90deg,var(--magenta) 0 4px,transparent 4px 7px)}

  /* ── Strategy cards ────────────────────────────────────────────────────── */
  .strat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:14px}
  .strat-card{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:14px;display:flex;flex-direction:column;gap:10px;transition:all .2s}
  .strat-card:hover{border-color:var(--line2)}
  .strat-card.off{opacity:.55}
  .strat-card .sc-head{display:flex;align-items:center;gap:10px}
  .strat-card .sc-num{font-size:11px;font-weight:800;color:var(--accent)}
  .strat-card .sc-name{flex:1;font-size:14px;font-weight:700}
  .strat-card .sc-desc{font-size:11px;color:var(--mut);line-height:1.4;min-height:30px}
  .strat-card .sc-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;text-align:center}
  .strat-card .sc-stat .lbl{font-size:9px;text-transform:uppercase;letter-spacing:.3px;color:var(--mut)}
  .strat-card .sc-stat .val{font-size:14px;font-weight:700;margin-top:2px}
  .strat-card .sc-spark{height:54px;position:relative}
  .wl{font-size:11px;font-weight:700}
  .wl .w{color:var(--green)} .wl .l{color:var(--red)}

  /* ── RL / Learning ─────────────────────────────────────────────────────── */
  .rl-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:16px}
  .rl-metric{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:14px}
  .rl-metric .lbl{font-size:9px;text-transform:uppercase;letter-spacing:.4px;color:var(--mut)}
  .rl-metric .val{font-size:24px;font-weight:800;margin-top:6px}
  .rl-metric .sub{font-size:11px;color:var(--mut);margin-top:4px}
  .pill{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.3px}
  .pill.active{background:rgba(0,208,132,.15);color:var(--green)}
  .pill.warmup{background:rgba(255,200,87,.15);color:var(--amber)}
  .pill.off{background:rgba(128,136,146,.15);color:var(--mut)}
  .progress{height:8px;background:var(--panel2);border-radius:4px;overflow:hidden;margin-top:8px}
  .progress > span{display:block;height:100%;background:var(--accent);border-radius:4px}
  .actbar{display:flex;height:8px;border-radius:4px;overflow:hidden;margin-top:8px;background:var(--panel2)}
  .actbar > div{height:100%}

  /* ── Pre-trade filters ─────────────────────────────────────────────────── */
  .filter-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px}
  .filter-grid .flt-item{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:9px 12px;border:1px solid var(--line);border-radius:8px;background:var(--panel2);font-size:13px;font-weight:600}

  /* ── Discover ──────────────────────────────────────────────────────────── */
  .dsc-layout{display:grid;grid-template-columns:2fr 1fr;gap:16px;align-items:start}
  .dsc-movers-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(420px,1fr));gap:16px;margin-top:16px}
  .dsc-main{display:flex;flex-direction:column;gap:16px}
  .dsc-split{display:grid;grid-template-columns:260px 1fr;gap:24px}
  .dsc-cats h3,.dsc-top h3,.dsc-news h3{margin-bottom:14px}
  .cat-item{display:flex;flex-direction:column;gap:6px;padding:10px 12px;border-radius:8px;cursor:pointer;border:1px solid transparent;transition:all .15s;margin-bottom:6px}
  .cat-item:hover{background:var(--panel2)}
  .cat-item.active{background:rgba(255,107,53,.08);border-color:rgba(255,107,53,.4)}
  .cat-item .cat-top{display:flex;justify-content:space-between;align-items:center;font-size:13px}
  .cat-item .cat-name{font-weight:600}
  .cat-item.active .cat-name{color:var(--accent)}
  .cat-item .cat-pct{font-size:12px;color:var(--mut);font-weight:600}
  .cat-bar{height:6px;background:var(--panel2);border-radius:3px;overflow:hidden}
  .cat-bar > span{display:block;height:100%;background:var(--accent);border-radius:3px;transition:width .3s}
  .cat-item.active .cat-bar > span{background:var(--accent)}

  .wheel-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(118px,1fr));gap:18px}
  .wheel{display:flex;flex-direction:column;align-items:center;gap:8px;cursor:default}
  .wheel .ring{position:relative;width:100px;height:100px}
  .wheel .ring:hover{transform:scale(1.04);transition:transform .15s}
  .wheel .ring svg{width:100%;height:100%;transform:rotate(-90deg)}
  .wheel .ring .ctr{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
  .wheel .ring .sym{font-size:13px;font-weight:800;letter-spacing:.3px}
  .wheel .ring .sub{font-size:10px;font-weight:700;margin-top:2px}
  .wheel .ring .sub.pos{color:var(--green)} .wheel .ring .sub.neg{color:var(--red)}
  .wheel .wlabel{font-size:11px;color:var(--mut);text-align:center}

  /* ── Risers / Fallers ──────────────────────────────────────────────────── */
  .mover-table{display:flex;flex-direction:column}
  .mover-row{display:grid;grid-template-columns:160px 1fr 90px 150px;gap:16px;align-items:center;padding:11px 6px;border-bottom:1px solid var(--line)}
  .mover-row:last-child{border-bottom:none}
  .mover-row.head{font-size:10px;text-transform:uppercase;letter-spacing:.4px;color:var(--mut);font-weight:600}
  .mover-row .mk{display:flex;align-items:center;gap:10px;font-weight:600;font-size:13px}
  .mover-row .mk .ic{width:26px;height:26px;border-radius:50%;background:var(--panel2);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;color:var(--mut);flex-shrink:0}
  .mover-row .mk .cat{font-size:9px;color:var(--mut);text-transform:uppercase;letter-spacing:.3px}
  .mbar{height:6px;background:var(--panel2);border-radius:3px;overflow:hidden}
  .mbar > span{display:block;height:100%;border-radius:3px}
  .mchg{font-size:13px;font-weight:700;text-align:right}
  .mchg.pos{color:var(--green)} .mchg.neg{color:var(--red)}
  .senti{display:flex;align-items:center;gap:14px;font-size:11px;color:var(--mut)}
  .senti .s{display:flex;align-items:center;gap:5px}
  .dot{width:9px;height:9px;border-radius:50%;background:var(--mut);flex-shrink:0}
  .dot.buy{background:var(--green)} .dot.sell{background:var(--red)} .dot.hold{background:var(--mut)}
  .dot.pos{background:var(--green)} .dot.neg{background:var(--red)} .dot.neu{background:var(--blue)}
  @media(max-width:760px){.mover-row{grid-template-columns:120px 1fr 70px;}.mover-row .senti{display:none}.mover-row.head .senti{display:none}}
  .dsc-spotlight-row{font-size:13px;color:var(--mut);border-top:1px solid var(--line);padding-top:12px}
  .dsc-spotlight-row .section-title{display:inline;margin-right:8px}

  .dsc-news .news-item{padding:10px 0;border-bottom:1px solid var(--line)}
  .dsc-news .news-item:last-child{border-bottom:none}
  .dsc-news .news-item .nt{font-size:13px;font-weight:600;line-height:1.4}
  .dsc-news .news-item .nm{font-size:10px;color:var(--mut);margin-top:4px}
  .dsc-news .news-item .ns{font-size:11px;color:var(--mut);margin-top:5px;line-height:1.5}

  @media(max-width:1100px){.dsc-layout{grid-template-columns:1fr}.dsc-split{grid-template-columns:220px 1fr}}
  @media(max-width:640px){.dsc-split{grid-template-columns:1fr}}

  /* ── Backtest result cards ─────────────────────────────────────────────── */
  .bt-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:14px}
  .bt-card{background:var(--panel);border:1px solid var(--line);border-radius:10px;padding:14px;display:flex;flex-direction:column;gap:10px}
  .bt-card .bt-head{display:flex;align-items:baseline;gap:8px}
  .bt-card .bt-num{font-size:11px;font-weight:800;color:var(--accent)}
  .bt-card .bt-name{font-size:14px;font-weight:700;flex:1}
  .bt-card .bt-bars{font-size:10px;color:var(--mut)}
  .bt-card .bt-chart{height:120px;position:relative}
  .bt-card .bt-metrics{display:grid;grid-template-columns:1fr 1fr;gap:4px 14px}
  .bt-card .bt-metrics .row{display:flex;justify-content:space-between;font-size:12px;padding:3px 0;border-bottom:1px solid var(--line)}
  .bt-card .bt-metrics .row .k{color:var(--mut)}
  .bt-card .bt-metrics .row .v{font-weight:600}

  /* ── Intelligence / news ───────────────────────────────────────────────── */
  .news-group{margin-bottom:16px}
  .news-group .ng-head{display:flex;align-items:center;gap:10px;margin-bottom:10px}
  .news-group .ng-title{font-size:13px;font-weight:700}
  .news-group .ng-tags{font-size:11px;color:var(--mut)}
  .news-group .ng-count{margin-left:auto;font-size:11px;color:var(--mut)}
  .article{border:1px solid var(--line);border-radius:8px;padding:12px 14px;margin-bottom:8px;background:var(--panel);transition:border-color .2s}
  .article:hover{border-color:var(--line2)}
  .article .a-head{display:flex;gap:10px;cursor:pointer;align-items:flex-start}
  .article .a-title{font-size:13px;font-weight:600;color:var(--txt);line-height:1.4;flex:1}
  .article .a-meta{font-size:10px;color:var(--mut);margin-top:4px}
  .article .a-snip{font-size:12px;color:var(--mut);line-height:1.5;margin-top:6px}
  .article .a-toggle{font-size:18px;color:var(--mut);line-height:1;transition:transform .2s;flex-shrink:0}
  .article.open .a-toggle{transform:rotate(45deg)}
  .article .a-full{display:none;font-size:12px;color:var(--mut);line-height:1.6;margin-top:8px;padding-top:8px;border-top:1px solid var(--line)}
  .article.open .a-full{display:block}
  .article .a-full a{color:var(--blue);text-decoration:none}
  .chip{display:inline-block;padding:1px 6px;border-radius:4px;font-size:9px;font-weight:700;background:var(--panel2);color:var(--mut);margin-right:4px}

  /* ── Responsive ────────────────────────────────────────────────────────── */
  @media(max-height:500px){
    .container{grid-template-rows:60px 1fr}
    .sidebar{grid-row:1/3;width:60px;padding:8px 0;gap:8px}
    .sidebar nav button{width:44px;height:44px}
    .topbar{padding:0 16px;gap:12px}
    .topbar .metrics{gap:12px}
    .topbar .metric-label{font-size:9px}
    .topbar .metric-value{font-size:14px}
    .main{padding:16px}
  }
  @media(max-width:768px){
    .container{grid-template-columns:1fr;grid-template-rows:60px auto 1fr}
    .sidebar{grid-row:2;grid-column:1;height:auto;flex-direction:row;overflow-x:auto;padding:12px 16px;gap:8px;border-right:none;border-bottom:1px solid var(--line)}
    .sidebar .logo-area{width:40px;height:40px;font-size:20px;margin-right:12px}
    .sidebar nav{flex-direction:row;gap:4px;flex:1;width:auto}
    .sidebar nav button{width:40px;height:40px;gap:1px}
    .sidebar nav button svg{width:18px;height:18px}
    .sidebar nav button span{font-size:7px}
    .topbar{grid-column:1;grid-row:1;padding:0 16px}
    .topbar .title{font-size:18px}
    .topbar .metrics{gap:16px}
    .topbar .metric-label{font-size:9px}
    .topbar .metric-value{font-size:14px}
    .topbar .divider{height:30px}
    .toggle-btn{padding:4px 8px;font-size:9px}
    .main{grid-column:1;grid-row:3;padding:16px}
    .account-grid{grid-template-columns:1fr}
    .signal-content{flex-direction:column;gap:12px}
    .confidence-circle{width:80px;height:80px}
    .confidence-text{font-size:24px}
    .grid.cols-3{grid-template-columns:repeat(auto-fit,minmax(200px,1fr))}
  }
  @media(max-width:480px){
    .container{grid-template-columns:1fr;grid-template-rows:56px auto 1fr}
    .sidebar{grid-row:2;padding:10px 12px;gap:6px}
    .sidebar .logo-area{width:36px;height:36px;font-size:18px;margin-right:8px}
    .sidebar nav button{width:36px;height:36px;padding:2px;gap:1px}
    .sidebar nav button svg{width:16px;height:16px}
    .sidebar nav button span{font-size:6px;letter-spacing:0}
    .topbar{padding:0 12px;gap:12px}
    .topbar .title{font-size:16px}
    .topbar .metrics{flex-wrap:wrap;gap:8px}
    .topbar .metric-label{font-size:8px}
    .topbar .metric-value{font-size:12px}
    .topbar .divider{display:none}
    .toggle-group{gap:4px}
    .toggle-btn{padding:3px 6px;font-size:8px}
    .main{padding:12px}
    h2.sec{font-size:10px;margin:16px 0 12px}
    .card{padding:12px;margin-bottom:12px}
    .account-grid{gap:12px}
    .balance-value{font-size:20px}
    .confidence-circle{width:70px;height:70px}
    .confidence-text{font-size:20px}
    .market-grid{grid-template-columns:1fr}
  }
</style>
</head>
<body>

<div id="kill-banner">⛔ KILL SWITCH ENGAGED — NO NEW ORDERS. Tap KILLED in the header to disengage.</div>

<div class="container">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="logo-area">O</div>
    <nav id="main-nav">
      <button class="nav-btn active" data-tab="overview" title="Overview"><svg viewBox="0 0 24 24" width="20" height="20"><rect x="2" y="4" width="5" height="16" fill="none" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="8" width="5" height="12" fill="none" stroke="currentColor" stroke-width="1.5"/><rect x="16" y="6" width="5" height="14" fill="none" stroke="currentColor" stroke-width="1.5"/></svg><span>OVR</span></button>
      <button class="nav-btn" data-tab="discover" title="Discover"><svg viewBox="0 0 24 24" width="20" height="20"><circle cx="12" cy="12" r="8" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="2" fill="currentColor"/></svg><span>DSC</span></button>
      <button class="nav-btn" data-tab="markets" title="Markets"><svg viewBox="0 0 24 24" width="20" height="20"><polyline points="2 20 6 12 10 16 14 8 22 4" fill="none" stroke="currentColor" stroke-width="1.5"/></svg><span>MKT</span></button>
      <button class="nav-btn" data-tab="strategies" title="Strategies"><svg viewBox="0 0 24 24" width="20" height="20"><circle cx="6" cy="6" r="2" fill="currentColor"/><circle cx="18" cy="6" r="2" fill="currentColor"/><circle cx="12" cy="16" r="2" fill="currentColor"/><line x1="6" y1="8" x2="12" y2="14" stroke="currentColor" stroke-width="1.5"/><line x1="18" y1="8" x2="12" y2="14" stroke="currentColor" stroke-width="1.5"/></svg><span>STR</span></button>
      <button class="nav-btn" data-tab="intelligence" title="Intelligence"><svg viewBox="0 0 24 24" width="20" height="20"><path d="M12 2 L2 8 L2 16 C2 20 12 22 12 22 C12 22 22 20 22 16 L22 8 Z" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="12" y1="12" x2="12" y2="18" stroke="currentColor" stroke-width="1.5"/></svg><span>INT</span></button>
      <button class="nav-btn" data-tab="learning" title="Learning"><svg viewBox="0 0 24 24" width="20" height="20"><path d="M4 5 L12 2 L20 5 L20 10 C20 15 12 20 12 20 C12 20 4 15 4 10 Z" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="12" y1="11" x2="12" y2="16" stroke="currentColor" stroke-width="1.5"/></svg><span>LRN</span></button>
      <button class="nav-btn" data-tab="signals" title="Signals"><svg viewBox="0 0 24 24" width="20" height="20"><line x1="2" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="1.5"/><polyline points="6 5 2 12 6 19" fill="none" stroke="currentColor" stroke-width="1.5"/><polyline points="18 5 22 12 18 19" fill="none" stroke="currentColor" stroke-width="1.5"/></svg><span>SIG</span></button>
      <button class="nav-btn" data-tab="trades" title="Trades"><svg viewBox="0 0 24 24" width="20" height="20"><rect x="3" y="5" width="18" height="14" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="14" x2="16" y2="14" stroke="currentColor" stroke-width="1.5"/></svg><span>TRD</span></button>
      <button class="nav-btn" data-tab="reports" title="Reports"><svg viewBox="0 0 24 24" width="20" height="20"><rect x="4" y="3" width="16" height="18" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="8" x2="16" y2="8" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="12" x2="16" y2="12" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="16" x2="13" y2="16" stroke="currentColor" stroke-width="1.5"/></svg><span>RPT</span></button>
      <button class="nav-btn" data-tab="backtest" title="Backtest"><svg viewBox="0 0 24 24" width="20" height="20"><circle cx="6" cy="6" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M18 3 Q21 6 18 9" fill="none" stroke="currentColor" stroke-width="1.5"/><polyline points="4 18 4 20 22 20" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="16" x2="8" y2="20" stroke="currentColor" stroke-width="1.5"/><line x1="16" y1="16" x2="16" y2="20" stroke="currentColor" stroke-width="1.5"/></svg><span>BT</span></button>
      <button class="nav-btn" data-tab="settings" title="Settings"><svg viewBox="0 0 24 24" width="20" height="20"><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="12" y1="8" x2="12" y2="10" stroke="currentColor" stroke-width="1.5"/><line x1="12" y1="14" x2="12" y2="16" stroke="currentColor" stroke-width="1.5"/></svg><span>SET</span></button>
    </nav>
  </div>

  <!-- TOP BAR -->
  <div class="topbar">
    <div class="title" id="page-title">Overview</div>

    <div class="right-section">
      <div class="metrics">
        <div class="metric-item">
          <div class="metric-label">Equity</div>
          <div class="metric-value bold" id="m-equity">—</div>
        </div>
        <div class="divider"></div>
        <div class="metric-group">
          <div class="metric-label">Real / Live</div>
          <div class="mg-rows">
            <div class="mg-row"><span class="mg-k">Closed</span><span class="mg-v" id="m-closed">—</span></div>
            <div class="mg-row"><span class="mg-k">Open</span><span class="mg-v" id="m-open">—</span></div>
          </div>
        </div>
        <div class="metric-group">
          <div class="metric-label shadow">Shadow</div>
          <div class="mg-rows">
            <div class="mg-row"><span class="mg-k">Closed</span><span class="mg-v" id="m-sh-closed">—</span></div>
            <div class="mg-row"><span class="mg-k">Open</span><span class="mg-v" id="m-sh-open">—</span></div>
          </div>
        </div>
        <div class="divider"></div>
        <div class="metric-item">
          <div class="metric-label">Daily P/L</div>
          <div class="metric-value" id="m-daily">—</div>
        </div>
      </div>

      <div class="divider"></div>
      <div class="conn-dot" id="conn" title="Connection to agent"></div>
      <span id="data-fresh" style="font-size:11px;font-weight:600;color:var(--mut);white-space:nowrap"
            title="How long ago the agent last published data. Green = live, amber = lagging, red = stale.">—</span>

      <div class="toggle-group">
        <button class="toggle-btn" id="mode-btn" title="Toggle Paper/Live mode">PAPER</button>
        <button class="toggle-btn" id="agent-btn" title="Toggle Agent On/Off">AGENT</button>
        <button class="toggle-btn" id="offgate-btn" title="Offline RL veto — blocks signals the offline policy disagrees with (veto-only, never upsizes)">RL VETO</button>
        <button class="toggle-btn" id="kill-btn" title="Hard stop: no new orders leave until disengaged. Independent of pause and the risk breakers.">KILL</button>
      </div>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div class="main">

    <!-- Overview -->
    <div id="overview" class="tab active">
      <h2 class="sec">Account</h2>
      <div class="account-grid">
        <div class="card">
          <h3>Account &amp; P&amp;L</h3>
          <div class="acct-head">
            <div class="acct-equity">
              <div class="metric-label">Current Equity</div>
              <span class="equity-big" id="ov-equity">—</span>
              <div class="balance-bar"></div>
              <div class="balance-text">Balance: <span id="ov-balance">—</span></div>
            </div>
            <div class="acct-pnl">
              <div class="metric-label">Total P&amp;L (Today)</div>
              <div class="pnl-row"><span class="k">Running</span><span class="v" id="ov-running">—</span></div>
              <div class="pnl-row"><span class="k">Closed</span><span class="v" id="ov-closed">—</span></div>
              <div class="pnl-row"><span class="k">Shadow</span><span class="v" id="ov-shadow-pl">—</span></div>
            </div>
          </div>
          <div class="section-divider"></div>
          <div class="execution-block">
            <div class="section-title" style="display:flex;justify-content:space-between;align-items:center">
              <span>Execution</span>
              <button class="btn ghost" style="padding:3px 8px;font-size:9px" onclick="resetShadow()" title="Clear shadow trading history and equity">Reset Shadow</button>
            </div>
            <div class="exec-items">
              <div class="exec-item">Real: <strong id="ov-real-open">0</strong> open / <span id="ov-real-total">0</span> total</div>
              <div class="exec-item">Shadow: <strong id="ov-shadow-open">0</strong> open / <span id="ov-shadow-total">0</span> total</div>
            </div>
          </div>
          <div class="rl-reward-block">
            <div class="section-title" style="display:flex;justify-content:space-between;align-items:center">
              <span>RL Reward</span>
              <button class="btn ghost" style="padding:3px 8px;font-size:9px" onclick="resetRL()" title="Reset RL policy to zero">Reset RL</button>
            </div>
            <div class="reward-value" id="ov-rl">0 updates</div>
          </div>
        </div>
        <div class="card chart-card">
          <div class="legend" style="position:absolute;top:14px;right:18px;z-index:2">
            <span class="lg"><span class="swatch" style="background:var(--green)"></span>Real</span>
            <span class="lg"><span class="swatch dash"></span>Shadow</span>
          </div>
          <div class="empty-state" id="ov-eq-empty">No closed trades yet — equity curve will appear here.</div>
          <canvas id="ov-eq-chart" style="display:none"></canvas>
        </div>
      </div>

      <h2 class="sec">Latest Signal</h2>
      <div class="signal-card card">
        <div class="signal-content">
          <div class="confidence-circle">
            <div class="confidence-text" id="sig-conf">0%<br><span>CONF</span></div>
          </div>
          <div class="signal-info">
            <div class="signal-badge" id="sig-badge">HOLD</div>
            <div class="signal-status" id="sig-status">No active signal</div>
            <div class="signal-waiting" id="sig-detail">Waiting for the agent…</div>
            <div class="signal-soft" id="sig-soft" style="margin-top:12px;padding-top:12px;border-top:1px solid var(--line);font-size:12px;color:var(--mut);display:none">
              <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px">
                <div><span style="color:var(--magenta)">Sentiment</span><br><span id="sig-sentiment" style="color:var(--txt);font-weight:600">—</span></div>
                <div><span style="color:var(--blue)">Prediction</span><br><span id="sig-prediction" style="color:var(--txt);font-weight:600">—</span></div>
                <div><span style="color:var(--purple)">RL Score</span><br><span id="sig-rl" style="color:var(--txt);font-weight:600">—</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div id="ov-consensus-sec" style="display:none">
        <style>
          .cons-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(176px,1fr));gap:10px}
          .cons-chip{background:var(--panel2);border:1px solid var(--line);border-radius:8px;
            padding:10px 12px;display:flex;flex-direction:column;gap:7px;min-width:0}
          .cons-chip .top{display:flex;align-items:center;justify-content:space-between;gap:8px}
          .cons-chip .sym{font-weight:700;font-size:13px}
          .cons-act{font-size:9px;font-weight:800;letter-spacing:.5px;text-transform:uppercase;
            padding:2px 7px;border-radius:5px;flex-shrink:0}
          .cons-act.enter{color:var(--green);background:rgba(0,208,132,.14)}
