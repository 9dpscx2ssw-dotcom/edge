function _sentiCls(score){ return score==null?'neu':(score>0.05?'pos':score<-0.05?'neg':'neu'); }
function _sentiLbl(score){ return score==null?'n/a':(score>0.05?'bullish':score<-0.05?'bearish':'neutral'); }
function moverRow(m, maxAbs){
  const chg=m.change_pct||0;
  const w = maxAbs>0 ? Math.max(5, Math.round(Math.abs(chg)/maxAbs*100)) : 0;
  const cls = chg>=0?'pos':'neg';
  const rl=(m.rl_direction||'HOLD'); const rlc=rl==='BUY'?'buy':rl==='SELL'?'sell':'hold';
  const sc=_sentiCls(m.sentiment);
  const ic=m.symbol.replace(/USD$/,'').replace(/[^A-Z0-9]/gi,'').slice(0,3).toUpperCase();
  return `<div class="mover-row">
    <div class="mk"><span class="ic">${ic}</span><div><div>${m.symbol}</div><div class="cat">${CAT_LABEL[m.category]||m.category||''}</div></div></div>
    <div class="mbar"><span style="width:${w}%;background:${chg>=0?C.green:C.red}"></span></div>
    <div class="mchg ${cls}">${(chg>=0?'+':'')+chg.toFixed(2)}%</div>
    <div class="senti">
      <span class="s" title="RL policy direction"><span class="dot ${rlc}"></span>RL ${rl}</span>
      <span class="s" title="Agent (LLM) sentiment"><span class="dot ${sc}"></span>Agent ${_sentiLbl(m.sentiment)}</span>
    </div>
  </div>`;
}
function renderMovers(up, elId, markets, limit){
  const el=$(elId); if(!el) return;
  let ms=(markets||[]).filter(m=>m.change_pct!=null && (up?m.change_pct>0:m.change_pct<0));
  ms.sort((a,b)=> up ? b.change_pct-a.change_pct : a.change_pct-b.change_pct);
  ms=ms.slice(0, limit||8);
  if(!ms.length){ el.innerHTML='<p style="color:var(--mut)">No '+(up?'risers':'fallers')+' right now.</p>'; return; }
  const maxAbs=Math.max(...ms.map(m=>Math.abs(m.change_pct)));
  el.innerHTML='<div class="mover-row head"><div>Market</div><div>Move</div><div style="text-align:right">Chg %</div><div>Sentiment</div></div>'
    + ms.map(m=>moverRow(m,maxAbs)).join('');
}

const CAT_LABEL = {FX:'Forex', Crypto:'Crypto', Commodities:'Commodities', Indices:'Indices'};
let DSC = { markets:[], news:[], cat:null };
async function loadDiscover(){
  try{
    const [md, intel] = await Promise.all([api('/api/markets'), api('/api/intelligence').catch(()=>({}))]);
    DSC.markets = md.markets||[];
    DSC.news = intel.news||[];

    // Aggregate per category: trade share (fall back to instrument count share).
    const cats={};
    DSC.markets.forEach(m=>{
      const c=m.category||'FX';
      const a=cats[c]||(cats[c]={cat:c, trades:0, count:0});
      a.trades+=m.trades||0; a.count+=1;
    });
    const useTrades = Object.values(cats).some(c=>c.trades>0);
    const total = useTrades ? Object.values(cats).reduce((s,c)=>s+c.trades,0)
                            : Object.values(cats).reduce((s,c)=>s+c.count,0);
    const list = Object.values(cats).map(c=>({...c, pct: total? Math.round((useTrades?c.trades:c.count)/total*100):0}))
                       .sort((a,b)=>b.pct-a.pct);
    if(!list.length){ $('dsc-cat-list').innerHTML='<p style="color:var(--mut)">No market data yet.</p>'; return; }
    if(!DSC.cat || !list.find(c=>c.cat===DSC.cat)) DSC.cat = list[0].cat;

    $('dsc-cat-list').innerHTML = list.map(c=>`
      <div class="cat-item ${c.cat===DSC.cat?'active':''}" onclick="selectCategory('${c.cat}')">
        <div class="cat-top"><span class="cat-name">${CAT_LABEL[c.cat]||c.cat}</span><span class="cat-pct">${c.pct}%</span></div>
        <div class="cat-bar"><span style="width:${c.pct}%"></span></div>
      </div>`).join('');

    renderDiscoverCategory();
    // Top risers / fallers cards (daily movers across all instruments).
    renderMovers(true, 'ris-list', DSC.markets, 8);
    renderMovers(false, 'fal-list', DSC.markets, 8);

    const bt=(STATUS.signal||{}).best_trade||{};
    $('dsc-spotlight').textContent = bt.symbol ? `${bt.strategy_name||'A strategy'} signals ${bt.direction} on ${bt.symbol} at ${bt.confidence}% confidence.` : 'No standout signal right now.';
