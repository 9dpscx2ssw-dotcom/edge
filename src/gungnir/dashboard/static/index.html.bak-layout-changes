function selectCategory(cat){ DSC.cat=cat;
  document.querySelectorAll('#dsc-cat-list .cat-item').forEach(el=>el.classList.remove('active'));
  renderDiscoverCategory();
  // Re-highlight without a full reload.
  const items=[...document.querySelectorAll('#dsc-cat-list .cat-item')];
  const idx=items.findIndex(el=>el.querySelector('.cat-name').textContent===(CAT_LABEL[cat]||cat));
  if(idx>=0) items[idx].classList.add('active');
}
function wheelRing(frac, color){
  const r=44, C=2*Math.PI*r, len=Math.max(0,Math.min(1,frac))*C;
  return `<svg viewBox="0 0 100 100">
    <circle cx="50" cy="50" r="${r}" fill="none" stroke="var(--line2)" stroke-width="3" stroke-dasharray="1.5 6" stroke-linecap="round"/>
    <circle cx="50" cy="50" r="${r}" fill="none" stroke="${color}" stroke-width="4.5" stroke-linecap="round" stroke-dasharray="${len.toFixed(1)} ${(C-len).toFixed(1)}"/>
  </svg>`;
}
function renderDiscoverCategory(){
  const cat=DSC.cat;
  $('dsc-cat-name').textContent = CAT_LABEL[cat]||cat;
  // Top traded instruments in this category → dotted fill wheels.
  const all=DSC.markets.filter(m=>(m.category||'FX')===cat)
    .sort((a,b)=>(b.trades||0)-(a.trades||0) || Math.abs(b.change_pct||0)-Math.abs(a.change_pct||0));
  const catTrades=all.reduce((s,m)=>s+(m.trades||0),0);
  const inst=all.slice(0,8);
  $('dsc-wheels').innerHTML = inst.length ? inst.map(m=>{
    const dir=(m.rl_direction||'HOLD');
    const color = dir==='BUY'?C.green:dir==='SELL'?C.red:C.mut;
    // Fill = this instrument's share of category trades; fall back to gauge.
    const frac = catTrades>0 ? (m.trades||0)/catTrades : Math.min(1, Math.abs(m.gauge||0)/100);
    const chg=m.change_pct;
    const chgCls = chg==null?'':(chg>=0?'pos':'neg');
    const chgTxt = chg==null?'':((chg>=0?'+':'')+chg+'%');
    const lbl = m.win_rate!=null?(m.win_rate+'% win'):(m.trades?(m.trades+' trades'):'no trades');
    return `<div class="wheel">
      <div class="ring">${wheelRing(frac,color)}<div class="ctr"><span class="sym">${m.symbol}</span>${chgTxt?`<span class="sub ${chgCls}">${chgTxt}</span>`:''}</div></div>
      <div class="wlabel">${lbl}</div>
    </div>`;
  }).join('') : '<p style="color:var(--mut)">No instruments in this category yet.</p>';

  // Related news: articles tagged with this category.
  $('dsc-news-cat').textContent = '· '+(CAT_LABEL[cat]||cat);
  const rel=DSC.news.filter(n=>(n.categories||[]).includes(cat) || n.group===cat);
  const show=(rel.length?rel:DSC.news).slice(0,8);
  $('dsc-news-list').innerHTML = show.length ? show.map(n=>{
    const snip=n.summary?esc(n.summary).slice(0,140)+(n.summary.length>140?'…':''):'';
    return `<div class="news-item"><div class="nt">${esc(n.title)}</div><div class="nm">${n.source||''}${(n.symbols||[]).length?' · '+n.symbols.slice(0,4).join(', '):''}</div>${snip?`<div class="ns">${snip}</div>`:''}</div>`;
  }).join('') : '<p style="color:var(--mut)">No related news.</p>';
}

