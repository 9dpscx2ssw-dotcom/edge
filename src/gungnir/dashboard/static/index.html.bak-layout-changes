const TEL_HIST = [];                 // client-side fast-loop history (last 24)
const TEL_SERIES = {real:'#3987e5', shadow:'#d55181', rejected:'#c98500'};

function telSpark(){
  const svg=$('tel-spark'); if(!svg||!TEL_HIST.length) return;
  const W=120,H=26,P=2,n=TEL_HIST.length,max=Math.max(8,...TEL_HIST);
  const x=i=>n>1?P+i*(W-2*P)/(n-1):W/2, y=v=>H-P-(v/max)*(H-2*P);
  const pts=TEL_HIST.map((v,i)=>`${x(i).toFixed(1)},${y(v).toFixed(1)}`).join(' ');
  svg.innerHTML=
    `<polygon points="${x(0)},${H-P} ${pts} ${x(n-1)},${H-P}" fill="rgba(57,135,229,.18)"/>`+
    `<polyline points="${pts}" fill="none" stroke="#3987e5" stroke-width="2" stroke-linejoin="round"/>`+
    `<circle cx="${x(n-1)}" cy="${y(TEL_HIST[n-1])}" r="2.6" fill="#3987e5" stroke="#1a1a24" stroke-width="1.2"/>`;
}

function telHist(slip){
  const hist=$('tel-hist'), xrow=$('tel-hist-x'), tip=$('tel-tip');
  const buckets=(slip&&slip.buckets)||[];
  if(!buckets.length){ hist.innerHTML=''; xrow.innerHTML=''; return; }
  const max=Math.max(1,...buckets.map(b=>b.n));
  const lbl=v=>v==null?'':(v===Math.round(v)?String(v):v.toFixed(1));
  hist.style.gridTemplateColumns=`repeat(${buckets.length},1fr)`;
  xrow.style.gridTemplateColumns=`repeat(${buckets.length},1fr)`;
  hist.innerHTML=''; xrow.innerHTML='';
  // zero reference line at the boundary where buckets cross from ≤0 to >0
  const zi=buckets.findIndex(b=>(b.from??-1e9)>=0);
  if(zi>0){ const z=document.createElement('div'); z.className='zero';
    z.style.left=(zi/buckets.length*100)+'%'; hist.appendChild(z); }
  buckets.forEach(b=>{
    const el=document.createElement('div'); el.className='bar';
    el.style.height=Math.max(2,(b.n/max)*80)+'px';
    const range=`${b.from==null?'≤':lbl(b.from)+'…'}${b.to==null?'+':lbl(b.to)}`;
    el.addEventListener('mousemove',e=>{
      tip.innerHTML=`<b>${b.n} fills</b> <span style="color:var(--mut)">· ${range} bps</span>`;
      tip.style.left=(e.clientX+12)+'px'; tip.style.top=(e.clientY-30)+'px'; tip.style.opacity=1;});
    el.addEventListener('mouseleave',()=>tip.style.opacity=0);
    hist.appendChild(el);
    const s=document.createElement('span'); s.textContent=b.to==null?'+∞':lbl(b.to);
    xrow.appendChild(s);
  });
}

