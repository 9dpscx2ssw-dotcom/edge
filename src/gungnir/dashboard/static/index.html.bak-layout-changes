function rpKpis(w){
  const C=rpColors(), sp=w.sparks||{}, dl=(RP_DATA.deltas&&RP_DATA.deltas[RP_WINDOW])||{};
  const ppm=v=>v==null?null:(v>=0?'+':'')+(v*100).toFixed(1)+'pp';
  const pf2=v=>v==null?null:(v>=0?'+':'')+(+v).toFixed(2);
  const num=v=>v==null?null:(v>=0?'+':'')+v;
  const per = RP_WINDOW==='daily'?'day':'7D';
  const cards=[
    {ic:'$',lbl:RP_WINDOW==='daily'?'Net P/L':'Weekly P/L',v:signed(w.pnl),cls:w.pnl>=0?'pos':'neg',
      spark:sp.pnl,scol:w.pnl>=0?C.green:C.red,d:signed(dl.pnl),dpos:(dl.pnl||0)>=0},
    {ic:'◎',lbl:'Win rate',v:rpPct(w.win_rate),spark:sp.win_rate,scol:C.accent,
      d:ppm(dl.win_rate),dpos:(dl.win_rate||0)>=0},
    {ic:'⌗',lbl:'Profit factor',v:rpPF(w.profit_factor),spark:sp.profit_factor,scol:C.accent,
      d:pf2(dl.profit_factor),dpos:(dl.profit_factor||0)>=0},
    {ic:'#',lbl:'Closed trades',v:String(w.trades),spark:sp.trades,scol:C.accent,
      d:num(dl.trades),dpos:(dl.trades||0)>=0},
    {ic:'◉',lbl:'Avg confidence',v:w.avg_confidence!=null?Math.round(w.avg_confidence*100)+'%':'—',
      spark:sp.confidence,scol:C.accent,d:ppm(dl.avg_confidence),dpos:(dl.avg_confidence||0)>=0},
    {ic:'▼',lbl:'Max drawdown',v:rpMoneyShort(-Math.abs(w.max_drawdown)),cls:'neg',
      spark:sp.drawdown,scol:C.red,d:signed(dl.max_drawdown),dpos:(dl.max_drawdown||0)<=0},
  ];
  document.getElementById('rp-kpis').innerHTML=cards.map(c=>{
    const dcls=c.d==null?'flat':(c.dpos?'pos':'neg');
    return `<div class="rp-kpi">
      <div class="top"><div class="ic">${c.ic}</div><div class="lbl">${c.lbl}</div></div>
      <div class="v ${c.cls||''}">${c.v}</div>
      ${rpSparkSvg(c.spark,c.scol,{area:true})}
      <div class="foot"><span class="cap">vs prev ${per}</span>
        <span class="d ${dcls}">${c.d==null?'—':c.d}</span></div></div>`;
  }).join('');
}

// --- cumulative P/L equity area chart ---
function rpEquity(w){
  const el=document.getElementById('rp-equity'), C=rpColors(), pts=w.equity_curve||[];
  const tot=document.getElementById('rp-eq-tot');
  tot.textContent=signed(w.pnl); tot.style.color=w.pnl>=0?C.green:C.red;
  if(pts.length<2){ el.innerHTML=`<text x="320" y="115" text-anchor="middle" fill="${C.mut}" font-size="12">Not enough trades to plot.</text>`; return; }
  const W=640,H=230,PL=52,PR=16,PT=14,PB=30;
  const ys=pts.map(p=>p.cum); let mn=Math.min(0,...ys), mx=Math.max(0,...ys); if(mn===mx){mx+=1;mn-=1;}
  const X=i=>PL+(i/(pts.length-1))*(W-PL-PR), Y=v=>H-PB-((v-mn)/(mx-mn))*(H-PT-PB);
  let g='';
  for(let k=0;k<=4;k++){ const v=mn+(mx-mn)*k/4, y=Y(v);
    g+=`<line x1="${PL}" y1="${y.toFixed(1)}" x2="${W-PR}" y2="${y.toFixed(1)}" stroke="${C.line}" stroke-width="1" ${Math.abs(v)<1e-9?'stroke-dasharray="4 4"':'opacity=".5"'}/>`;
    g+=`<text x="${PL-8}" y="${(y+3).toFixed(1)}" text-anchor="end" fill="${C.mut}" font-size="10">${rpMoneyShort(v)}</text>`; }
  const d=pts.map((p,i)=>(i?'L':'M')+X(i).toFixed(1)+' '+Y(p.cum).toFixed(1)).join(' '), base=H-PB;
  g+=`<path d="${d} L ${X(pts.length-1).toFixed(1)} ${base} L ${X(0).toFixed(1)} ${base} Z" fill="${C.accent}" opacity=".10"/>`;
  g+=`<path d="${d}" fill="none" stroke="${C.accent}" stroke-width="2" stroke-linejoin="round"/>`;
  const lx=X(pts.length-1), ly=Y(pts[pts.length-1].cum);
  g+=`<circle cx="${lx.toFixed(1)}" cy="${ly.toFixed(1)}" r="3.5" fill="${C.accent}"/>`;
  const d0=pts[0].t?new Date(pts[0].t):null, d1=pts[pts.length-1].t?new Date(pts[pts.length-1].t):null;
  if(d0) g+=`<text x="${PL}" y="${H-9}" fill="${C.mut}" font-size="10">${rpDay(d0)}</text>`;
  if(d1) g+=`<text x="${W-PR}" y="${H-9}" text-anchor="end" fill="${C.mut}" font-size="10">${rpDay(d1)}</text>`;
  el.innerHTML=g;
}

// --- P/L by instrument diverging bars (share of net) ---
function rpIbars(w){
  const host=document.getElementById('rp-ibars'), axis=document.getElementById('rp-iaxis'), C=rpColors();
  const rows=(w.by_instrument||[]).slice(0,8);
  if(!rows.length){ host.innerHTML='<div class="rp-empty">No closed trades in this window.</div>'; axis.innerHTML=''; return; }
  const gross=rows.reduce((a,r)=>a+Math.abs(r.pnl),0), mx=Math.max(1,...rows.map(r=>Math.abs(r.pnl)));
  const lo=-mx, hi=mx, rg=hi-lo, zero=(0-lo)/rg*100;
  host.innerHTML=rows.map(r=>{
    const vx=(r.pnl-lo)/rg*100, left=Math.min(zero,vx), wdt=Math.abs(vx-zero), wide=wdt>=20;
    const col=r.pnl>=0?C.green:C.red;
    const share=gross>0?(r.pnl/gross*100):null;
    const vlabel=r.pnl>=0
      ? (wide?`right:${(100-vx).toFixed(2)}%;transform:translateX(-8px);color:#0a0a0f`
             :`left:${vx.toFixed(2)}%;transform:translateX(8px);color:${C.green}`)
      : (wide?`right:${(100-zero).toFixed(2)}%;transform:translateX(-8px);color:#0a0a0f`
             :`left:${vx.toFixed(2)}%;transform:translateX(calc(-100% - 8px));color:${C.red}`);
    return `<div class="rp-ibar"><span class="sym">${rpTrunc(r.name,8)}</span>
      <div class="track"><div class="z" style="left:${zero.toFixed(2)}%"></div>
        <i style="left:${left.toFixed(2)}%;width:${wdt.toFixed(2)}%;background:${col}"></i>
        <span class="v" style="${vlabel}">${signed(r.pnl)}</span></div>
      <span class="pct">${share==null?'—':(share>=0?'+':'')+share.toFixed(1)+'%'}</span></div>`;
  }).join('');
  axis.innerHTML=`<span>${rpMoneyShort(lo)}</span><span>$0</span><span>${rpMoneyShort(hi)}</span>`;
}

// --- signal quality: confidence gauge + real/shadow distribution ---
function rpSignal(w){
  const C=rpColors();
  const frac=w.avg_confidence!=null?Math.max(0,Math.min(1,w.avg_confidence)):0;
  const cx=60,cy=60,r=48,sw=11,start=135,sweep=270;
  const P=(a,rr)=>[cx+rr*Math.cos(a*Math.PI/180),cy+rr*Math.sin(a*Math.PI/180)];
  const arc=(a0,a1,col)=>{const[x0,y0]=P(a0,r),[x1,y1]=P(a1,r),large=(a1-a0)>180?1:0;
    return `<path d="M ${x0.toFixed(1)} ${y0.toFixed(1)} A ${r} ${r} 0 ${large} 1 ${x1.toFixed(1)} ${y1.toFixed(1)}" fill="none" stroke="${col}" stroke-width="${sw}" stroke-linecap="round"/>`;};
  let g=arc(start,start+sweep,C.line); if(frac>0) g+=arc(start,start+sweep*frac,C.accent);
  const label=w.avg_confidence!=null?Math.round(w.avg_confidence*100)+'%':'—';
  document.getElementById('rp-donut').innerHTML=
    `<svg viewBox="0 0 120 120" style="width:120px;height:120px">${g}</svg><div class="mid"><b>${label}</b></div>`;

  const sd=w.signal_dist||{real:{trades:0,pnl:0},shadow:{trades:0,pnl:0}};
  const total=(sd.real.trades||0)+(sd.shadow.trades||0);
  const rows=[{nm:'Real',c:C.green,t:sd.real.trades,pnl:sd.real.pnl},
              {nm:'Shadow',c:C.blue,t:sd.shadow.trades,pnl:sd.shadow.pnl}];
  document.getElementById('rp-sigdist').innerHTML=rows.map(r=>{
    const pct=total?Math.round(r.t/total*100):0;
    return `<div class="row"><div class="hd">
      <span class="nm"><i style="background:${r.c}"></i>${r.nm}</span>
      <span class="val">${r.t} <span style="color:var(--mut);font-weight:500">(${pct}%) · ${signed(r.pnl)}</span></span></div>
      <div class="bar"><span style="width:${pct}%;background:${r.c}"></span></div></div>`;
  }).join('')+`<div class="tot"><span>TOTAL CLOSED</span><b>${total.toLocaleString()}</b></div>`;
}

// --- strategy scorecard: dual-axis P/L bars + win-rate dots ---
function rpScore(w){
  const el=document.getElementById('rp-score'), C=rpColors();
  const d=(w.by_strategy||[]).slice(0,6);
  if(!d.length){ el.innerHTML=`<text x="280" y="125" text-anchor="middle" fill="${C.mut}" font-size="12">No closed trades in this window.</text>`; return; }
  const W=560,H=250,PL=46,PR=42,PT=18,PB=42;
  const pls=d.map(s=>s.pnl); let mx=Math.max(0,...pls), mn=Math.min(0,...pls);
  const pad=(mx-mn)*0.18||100; mx+=pad; mn-=pad;
  const y=v=>H-PB-((v-mn)/(mx-mn))*(H-PT-PB), yw=v=>H-PB-(v/100)*(H-PT-PB);
  const step=(W-PL-PR)/d.length, bw=Math.min(40,step*0.5);
  let g='';
  for(let k=0;k<=4;k++){ const v=mn+(mx-mn)*k/4, yy=y(v);
    g+=`<line x1="${PL}" y1="${yy.toFixed(1)}" x2="${W-PR}" y2="${yy.toFixed(1)}" stroke="${C.line}" stroke-width="1" ${Math.abs(v)<1e-9?'stroke-dasharray="4 4"':'opacity=".5"'}/>`;
    g+=`<text x="${PL-7}" y="${(yy+3).toFixed(1)}" text-anchor="end" fill="${C.mut}" font-size="9">${rpMoneyShort(v)}</text>`; }
  [0,25,50,75,100].forEach(v=>{ g+=`<text x="${W-PR+7}" y="${(yw(v)+3).toFixed(1)}" fill="${C.mut}" font-size="9">${v}%</text>`; });
  const halo=(x,y,fill,txt,size=10)=>`<text x="${x.toFixed(1)}" y="${y.toFixed(1)}" text-anchor="middle" `
    +`fill="${fill}" font-size="${size}" font-weight="700" paint-order="stroke" stroke="${C.panel}" `
    +`stroke-width="3" stroke-linejoin="round">${txt}</text>`;
  d.forEach((s,i)=>{ const cx=PL+step*i+step/2, y0=y(0), y1=y(s.pnl);
    const top=Math.min(y0,y1), bot=Math.max(y0,y1), h=bot-top, col=s.pnl>=0?C.accent:C.red;
    const wy=yw((s.win_rate||0)*100);
    // bar and win-rate dot first, then haloed labels on top so nothing paints over the text
    g+=`<rect x="${(cx-bw/2).toFixed(1)}" y="${top.toFixed(1)}" width="${bw.toFixed(1)}" height="${Math.max(1,h).toFixed(1)}" rx="4" fill="${col}" opacity=".92"/>`;
    g+=`<circle cx="${cx.toFixed(1)}" cy="${wy.toFixed(1)}" r="4.5" fill="${C.blue}" stroke="${C.panel}" stroke-width="1.5"/>`;
    const plTxt=signed(s.pnl);
    if(s.pnl>=0 && h>=20) g+=`<text x="${cx.toFixed(1)}" y="${(top+14).toFixed(1)}" text-anchor="middle" fill="#0a0a0f" font-size="10" font-weight="700">${plTxt}</text>`;
    else g+=halo(cx, s.pnl>=0?top-6:bot+13, C.txt, plTxt);
    // win-rate % below the dot when the dot sits high (near a short bar's value), else above
    const wlY = wy < top+4 ? wy+16 : wy-9;
    g+=halo(cx, wlY, C.blue, Math.round((s.win_rate||0)*100)+'%');
    g+=`<text x="${cx.toFixed(1)}" y="${(H-14).toFixed(1)}" text-anchor="middle" fill="${C.txt}" font-size="10" font-weight="600">${rpTrunc(s.name,9)}</text>`;
  });
  el.innerHTML=g;
}

// --- instrument x strategy heatmap (diverging, direct-labelled) ---
function rpHeat(w){
  const el=document.getElementById('rp-heat'), C=rpColors();
  const m=w.matrix||{instruments:[],strategies:[],cells:[]};
  const bar=document.getElementById('rp-hm-bar');
  if(!m.instruments.length||!m.strategies.length){
    el.innerHTML='<tr><td class="rp-empty">No closed trades in this window.</td></tr>';
    bar.style.background='var(--panel2)';
    document.getElementById('rp-hm-lo').textContent=''; document.getElementById('rp-hm-hi').textContent=''; return; }
  const insts=m.instruments.slice(0,6), strats=m.strategies.slice(0,6);
  let cap=1;
  insts.forEach((_,ri)=>strats.forEach((_,ci)=>{ const v=m.cells[ri]&&m.cells[ri][ci];
    if(v!=null) cap=Math.max(cap,Math.abs(v)); }));
  const col=v=>{ const t=Math.max(-1,Math.min(1,v/cap)), mid=[36,42,53],
    to=t>=0?[0,208,132]:[255,56,96], k=Math.abs(t);
    return 'rgb('+mid.map((c,i)=>Math.round(c+(to[i]-c)*Math.pow(k,.7))).join(',')+')'; };
  let h=`<tr><td></td>`+strats.map(s=>`<td class="cl">${rpTrunc(s,8)}</td>`).join('')+`</tr>`;
  insts.forEach((sym,ri)=>{ h+=`<tr><td class="rl">${rpTrunc(sym,8)}</td>`+strats.map((s,ci)=>{
    const v=m.cells[ri]&&m.cells[ri][ci];
    if(v==null) return `<td><div class="cell empty">·</div></td>`;
    const txtCol=Math.abs(v)/cap<0.4?C.txt:'#0a0a0f';
    return `<td><div class="cell" style="background:${col(v)};color:${txtCol}">${signed(v)}</div></td>`;
  }).join('')+`</tr>`; });
  el.innerHTML=h;
  document.getElementById('rp-hm-lo').textContent='≤ −'+rpMoneyShort(cap).replace('-','');
  document.getElementById('rp-hm-hi').textContent='≥ '+rpMoneyShort(cap);
  bar.style.background=`linear-gradient(90deg, ${C.red}, ${C.panel2}, ${C.green})`;
}

// --- top / bottom instrument x strategy combinations ---
function rpCombos(w){
  const el=document.getElementById('rp-combos'), cb=w.combos||[];
  const top=cb.slice(0,3), topNames=new Set(top.map(r=>r.name));
  const bottom=cb.slice().reverse().filter(r=>!topNames.has(r.name)).slice(0,3);
  const rows=arr=>arr.length?arr.map((r,i)=>`<div class="r"><span class="rk">${i+1}</span>
    <span class="nm">${r.name}</span><span class="pl ${r.pnl>=0?'pos':'neg'}">${signed(r.pnl)}</span></div>`).join('')
    :'<div class="rp-empty">—</div>';
  el.innerHTML=`<h4>Top combinations <span>P/L</span></h4>${rows(top)}`
    +`<h4>Bottom combinations <span>P/L</span></h4>${rows(bottom)}`;
}

// --- extended risk/return metric grid ---
function rpMgrid(w){
  const el=document.getElementById('rp-mgrid'), mm=w.metrics||{};
  const cells=[
    {k:'Sharpe',v:rpFmt(w.sharpe,2)},
    {k:'Sortino',v:rpFmt(mm.sortino,2)},
    {k:'Profit factor',v:rpPF(w.profit_factor)},
    {k:'Payoff ratio',v:mm.payoff_ratio==null?'—':rpFmt(mm.payoff_ratio,2)},
    {k:'Expectancy',v:signed(w.expectancy),cls:w.expectancy>=0?'pos':'neg',s:'per trade'},
    {k:'Recovery',v:mm.recovery_factor==null?'—':rpFmt(mm.recovery_factor,2),s:'net / max DD'},
    {k:'Kelly',v:mm.kelly==null?'—':(mm.kelly*100).toFixed(1)+'%',s:'suggested size'},
    {k:'Max drawdown',v:rpMoneyShort(-Math.abs(w.max_drawdown||0)),cls:'neg'},
    {k:'Avg win',v:signed(mm.avg_win),cls:'pos'},
    {k:'Avg loss',v:mm.avg_loss?('-'+rpFmt(mm.avg_loss,2)):'—',cls:'neg'},
    {k:'Streak',v:(mm.current_streak>0?mm.current_streak+'W':mm.current_streak<0?(-mm.current_streak)+'L':'—'),
      s:`max ${mm.max_win_streak||0}W / ${mm.max_loss_streak||0}L`},
    {k:'Avg hold',v:mm.avg_hold_min==null?'—':rpHold(mm.avg_hold_min)},
  ];
  el.innerHTML=cells.map(c=>`<div class="rp-m"><span class="k">${c.k}</span>
    <span class="v ${c.cls||''}">${c.v}</span>${c.s?`<span class="s">${c.s}</span>`:''}</div>`).join('');
}
function rpHold(min){ if(min<60) return Math.round(min)+'m'; const h=min/60;
  return h<24?h.toFixed(1)+'h':(h/24).toFixed(1)+'d'; }

// --- P/L distribution histogram ---
function rpHist(w){
  const el=document.getElementById('rp-hist'), C=rpColors();
  const dist=w.distribution||{bins:[],max_abs:0}, bins=dist.bins||[];
  document.getElementById('rp-hist-n').textContent=w.trades?`${w.trades} trades`:'';
  if(!bins.length||w.trades===0){ el.innerHTML=`<text x="210" y="75" text-anchor="middle" fill="${C.mut}" font-size="12">No closed trades.</text>`; return; }
  const W=420,H=150,PL=8,PR=8,PT=14,PB=26, n=bins.length, bw=(W-PL-PR)/n;
  const counts=bins.map(b=>b.count), mx=Math.max(1,...counts); let g='';
  bins.forEach((b,i)=>{ const x=PL+i*bw, h=(b.count/mx)*(H-PT-PB), yy=H-PB-h, cc=b.mid>=0?C.green:C.red;
    g+=`<rect x="${(x+2).toFixed(1)}" y="${yy.toFixed(1)}" width="${(bw-4).toFixed(1)}" height="${Math.max(0,h).toFixed(1)}" rx="2" fill="${cc}" opacity=".85"/>`;
    if(b.count>0) g+=`<text x="${(x+bw/2).toFixed(1)}" y="${(yy-4).toFixed(1)}" text-anchor="middle" fill="${C.mut}" font-size="9">${b.count}</text>`; });
  g+=`<text x="${PL}" y="${H-8}" fill="${C.mut}" font-size="9">${rpMoneyShort(-dist.max_abs)}</text>`;
  g+=`<text x="${W/2}" y="${H-8}" text-anchor="middle" fill="${C.mut}" font-size="9">$0</text>`;
  g+=`<text x="${W-PR}" y="${H-8}" text-anchor="end" fill="${C.mut}" font-size="9">${rpMoneyShort(dist.max_abs)}</text>`;
  el.innerHTML=g;
}

function rpRenderWindow(){
  if(!RP_DATA) return;
  const w = RP_DATA[RP_WINDOW];
  document.getElementById('rp-tab-daily').classList.toggle('active', RP_WINDOW==='daily');
  document.getElementById('rp-tab-daily').setAttribute('aria-selected', RP_WINDOW==='daily');
  document.getElementById('rp-tab-weekly').classList.toggle('active', RP_WINDOW==='weekly');
  document.getElementById('rp-tab-weekly').setAttribute('aria-selected', RP_WINDOW==='weekly');

  rpKpis(w);
  rpEquity(w);
  rpIbars(w);
  rpSignal(w);
  rpScore(w);
  rpHeat(w);
  rpCombos(w);
  rpMgrid(w);
  rpHist(w);

  // best / worst trade
  const ex = document.getElementById('rp-extremes');
  const exCard=(cls,label,t)=> t ? `
    <div class="rp-ex ${cls}"><span class="badge">${label}</span>
      <div class="body"><div class="pnl ${t.pnl>=0?'pos':'neg'}" style="color:${t.pnl>=0?'var(--green)':'var(--red)'}">${signed(t.pnl)}</div>
      <div class="who">${t.symbol} · ${t.strategy} · ${t.side.toUpperCase()} · ${t.mode}</div></div></div>` : '';
  ex.innerHTML = (w.best_trade||w.worst_trade)
    ? exCard('best','Best trade',w.best_trade)+exCard('worst','Worst trade',w.worst_trade) : '';

  // breakdown tables
  const fill=(id,rows,nId)=>{
    const tb=document.getElementById(id).querySelector('tbody');
    document.getElementById(nId).textContent = rows.length?`${rows.length} · net ${signed(w.pnl)}`:'';
    tb.innerHTML = rows.length ? rows.map(rpRow).join('')
      : `<tr><td colspan="7" class="rp-empty">No closed trades in this window.</td></tr>`;
  };
  fill('rp-strat', w.by_strategy, 'rp-strat-n');
  fill('rp-inst', w.by_instrument, 'rp-inst-n');
  const sides=[w.by_side.buy, w.by_side.sell].filter(r=>r.trades>0);
  document.getElementById('rp-side').querySelector('tbody').innerHTML =
    sides.length ? sides.map(rpRow).join('') : `<tr><td colspan="7" class="rp-empty">No closed trades in this window.</td></tr>`;
}

function rpSetWindow(w){ RP_WINDOW=w; rpRenderWindow(); }

async function loadReports(){
  try{
    RP_DATA = await api('/api/performance');
    document.getElementById('rp-summary').textContent = RP_DATA.summary || '—';
    const g = RP_DATA.generated_at ? new Date(RP_DATA.generated_at) : null;
    document.getElementById('rp-generated').textContent =
      g ? 'generated '+g.toLocaleString() : '';
    rpRenderWindow();
  }catch(e){
    document.getElementById('rp-summary').textContent = 'Could not load performance data.';
  }
}

function tradeSection(title, headers, rows, colspan, empty){
  return `<h4 style="margin:14px 0 8px;color:var(--accent);text-transform:uppercase;letter-spacing:.7px;font-size:11px">${title}</h4><table class="data-table"><thead><tr>${headers.map(h=>`<th>${h}</th>`).join('')}</tr></thead><tbody>${rows.length?rows.join(''):`<tr><td colspan="${colspan}" style="color:var(--mut)">${empty}</td></tr>`}</tbody></table>`;
}
function byMode(rows){ return {real:rows.filter(t=>['real','live'].includes(String(t.mode||'').toLowerCase())),shadow:rows.filter(t=>!['real','live'].includes(String(t.mode||'').toLowerCase()))}; }
async function loadTrades(){
  loadTelemetry();
  const opens=(STATUS.open_trades)||[], om=byMode(opens), view=STATUS.views||{};
  const closeBtn=(sym)=>`<button class="btn ghost" style="padding:4px 8px;font-size:10px" onclick="closePosition('${sym}')">Close</button>`;
  const openHeaders=['Opened','Symbol','Dir','Vol','Entry','Current Price','TP','SL','Running P&amp;L','Conf','Action'];
  const openRows=rs=>rs.map(t=>{const q=view[t.symbol]||{}; const cp=t.current_price??q.live_price??q.price; return `<tr><td>${ts19(t.opened_at)}</td><td>${t.symbol}</td><td>${t.direction}</td><td>${t.size??'—'}</td><td>${t.entry??'—'}</td><td>${cp??'—'}</td><td>${t.tp??t.take_profit??'—'}</td><td>${t.sl??t.stop_loss??'—'}</td><td class="${(t.running_pnl||0)>=0?'pos':'neg'}">${t.running_pnl!=null?signed(t.running_pnl):'—'}</td><td>${t.confidence!=null?t.confidence+'%':'—'}</td><td>${closeBtn(t.symbol)}</td></tr>`});
