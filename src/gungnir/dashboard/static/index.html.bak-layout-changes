// Sparkline as a standalone <svg> string (single hue; optional faint area fill).
function rpSparkSvg(vals, color, {area=false, w=120, h=34}={}){
  const v=(vals||[]).map(x=>x==null?null:+x), good=v.filter(x=>x!=null);
  if(good.length<2) return `<svg viewBox="0 0 ${w} ${h}" preserveAspectRatio="none"></svg>`;
  let mn=Math.min(...good), mx=Math.max(...good); if(mn===mx){mn-=1;mx+=1;}
  const pad=3, X=i=>pad+(i/(v.length-1))*(w-2*pad), Y=y=>h-pad-((y-mn)/(mx-mn))*(h-2*pad);
  let d='', started=false; const xs=[];
  v.forEach((y,i)=>{ if(y==null){started=false;return;} xs.push(i);
    d+=(started?'L':'M')+X(i).toFixed(1)+' '+Y(y).toFixed(1)+' '; started=true; });
  let fill='';
  if(area && xs.length>1){ const x0=X(xs[0]), x1=X(xs[xs.length-1]);
    fill=`<path d="${d}L ${x1.toFixed(1)} ${(h-pad).toFixed(1)} L ${x0.toFixed(1)} ${(h-pad).toFixed(1)} Z" fill="${color}" opacity=".13"/>`; }
  return `<svg viewBox="0 0 ${w} ${h}" preserveAspectRatio="none">${fill}`
    +`<path d="${d.trim()}" fill="none" stroke="${color}" stroke-width="1.6" stroke-linejoin="round" stroke-linecap="round"/></svg>`;
}

